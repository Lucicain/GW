using System;
using System.Collections.Generic;
using System.Linq;
using TaleWorlds.CampaignSystem;
using TaleWorlds.CampaignSystem.Actions;
using TaleWorlds.CampaignSystem.MapEvents;
using TaleWorlds.CampaignSystem.Party;
using TaleWorlds.CampaignSystem.Settlements;
using TaleWorlds.Core;
using TaleWorlds.Library;
using static TaleWorlds.CampaignSystem.Party.MobileParty;

namespace GreyWardenPolicePurity
{
    /// <summary>
    /// 警察惩戒系统
    ///
    /// 1. 追击罪犯（不宣战）
    /// 2. 超近距离时：对罪犯的MapFaction宣战
    /// 3. 战斗自然发生
    /// 4. 胜利 → 任务完成
    /// 5. 失败 → 另一个警察接手
    /// 6. 和平由 PoliceAntiWarDeclaration 统一处理
    /// 7. 犯罪池由 CrimePool 统一管理
    /// </summary>
    public class PoliceEnforcementBehavior : CampaignBehaviorBase
    {
        private const float WarDistance = 3f;
        // 玩家可能主动靠近警察，需要更远距离提前宣战，否则引擎会先触发对话导致卡死
        private const float WarDistancePlayer = 15f;

        // 押送状态：是否有警察正在押送玩家（用于 OnTick 快速跳过）
        private bool _hasActiveEscort = false;


        public override void RegisterEvents()
        {
            PoliceCrimeMonitorEnhanced.OnCrimeDetected += HandleCrimeDetected;
            CampaignEvents.MapEventEnded.AddNonSerializedListener(this, OnMapEventEnded);
            CampaignEvents.HourlyTickEvent.AddNonSerializedListener(this, OnHourlyTick);
            CampaignEvents.TickEvent.AddNonSerializedListener(this, OnTick);
        }

        public override void SyncData(IDataStore dataStore)
        {
            if (dataStore.IsLoading)
            {
                _hasActiveEscort = false;
            }
        }



        #region 犯罪通知

        private void HandleCrimeDetected(string crimeType, MobileParty offender, Vec2 location, string victimName)
        {
            CrimePool.TryAdd(crimeType, offender, location, victimName);
        }

        #endregion

        #region 每帧检查押送距离

        private void OnTick(float dt)
        {
            if (!_hasActiveEscort) return;

            try
            {
                foreach (var kvp in CrimePool.ActiveTasks.ToList())
                {
                    var task = kvp.Value;
                    if (!task.IsEscortingPlayer) continue;

                    Settlement target = task.EscortSettlement;
                    if (target == null) continue;

                    var pp = MobileParty.All.FirstOrDefault(p => p.StringId == task.PolicePartyId);
                    if (pp == null || !pp.IsActive)
                    {
                        // 警察消失 → 立刻和平释放 + 惩罚
                        FinishEscort(null, task, kvp.Key, target);
                        return;
                    }

                    float dist = pp.GetPosition2D.Distance(target.Position.ToVec2());
                    if (dist < 5f)
                    {
                        FinishEscort(pp, task, kvp.Key, target);
                        return;
                    }
                }
            }
            catch { }
        }

        /// <summary>
        /// 押送结束：和平 → 引擎自动释放俘虏 → 惩罚
        /// </summary>
        private void FinishEscort(MobileParty pp, PoliceTask task, string taskKey, Settlement settlement)
        {
            // 1. 和平 → 引擎自动释放俘虏
            MakePeaceWithAllFactions();

            // 2. 安全网
            try { if (PlayerCaptivity.IsCaptive) PlayerCaptivity.EndCaptivity(); } catch { }

            // 3. 罚款
            int rep = PlayerBehaviorPool.Reputation;
            int fine = Math.Abs(rep) * 100;
            int playerGold = Hero.MainHero.Gold;
            if (playerGold >= fine)
                Hero.MainHero.ChangeHeroGold(-fine);
            else
            {
                if (playerGold > 0) Hero.MainHero.ChangeHeroGold(-playerGold);
                fine = playerGold;
            }

            // 4. 声望归零 + 解除通缉
            PlayerBehaviorPool.ResetReputation(0);
            CrimePool.EndPlayerHunt();

            string townName = settlement?.Name?.ToString() ?? "城镇";
            InformationManager.DisplayMessage(new InformationMessage(
                $"[GWP] 你被押送至 {townName}，缴纳罚款 {fine} 金，通缉已解除",
                Colors.Yellow));

            // 5. 恢复警察
            if (pp != null && pp.IsActive)
            {
                RestoreAi(pp);
                PoliceResourceManager.StartResupply(pp);
            }

            CrimePool.EndTask(taskKey);
            _hasActiveEscort = false;
        }

        #endregion

        #region 每小时

        private void OnHourlyTick()
        {
            // 安全网：如果玩家仍处于被警察俘虏的残留状态，强制和平释放
            SafetyReleaseCaptivePlayer();

            CrimePool.Clean();

            AssignTasks();
            UpdateTasks();
            CrimePool.RefreshAccepting();
        }

        private void SafetyReleaseCaptivePlayer()
        {
            if (!PlayerCaptivity.IsCaptive) return;

            try
            {
                PartyBase captorParty = PlayerCaptivity.CaptorParty;
                if (captorParty == null) return;

                Clan policeClan = PoliceStats.GetPoliceClan();
                if (policeClan == null) return;

                bool isCapturedByPolice = false;
                if (captorParty.IsMobile && captorParty.MobileParty?.ActualClan == policeClan)
                    isCapturedByPolice = true;
                if (captorParty.IsSettlement && captorParty.Settlement?.OwnerClan == policeClan)
                    isCapturedByPolice = true;

                if (!isCapturedByPolice) return;

                MakePeaceWithAllFactions();
                try { PlayerCaptivity.EndCaptivity(); } catch { }

                InformationManager.DisplayMessage(new InformationMessage(
                    "[GWP] 灰袍守卫已释放你", Colors.Green));
            }
            catch { }
        }

        private void AssignTasks()
        {
            foreach (var pp in PoliceStats.GetAllPoliceParties())
            {
                if (CrimePool.HasTask(pp.StringId)) continue;
                if (!PoliceResourceManager.IsReady(pp)) continue;

                CrimeRecord crime = CrimePool.GetNearest(pp.GetPosition2D);
                if (crime == null) continue;

                BeginTask(pp, crime);
            }
        }

        private void BeginTask(MobileParty police, CrimeRecord crime)
        {
            CrimePool.BeginTask(police.StringId, crime);

            police.SetMoveEngageParty(crime.Offender, NavigationType.Default);
            police.Ai.SetDoNotMakeNewDecisions(true);
            police.Ai.SetInitiative(1f, 0f, 999f);

            InformationManager.DisplayMessage(new InformationMessage(
                $"[GWP 出警] {police.Name} → {crime.Offender.Name}（{crime.CrimeType}）",
                Colors.Cyan));
        }

        private void UpdateTasks()
        {
            foreach (var kvp in CrimePool.ActiveTasks.ToList())
            {
                var task = kvp.Value;
                var pp = MobileParty.All.FirstOrDefault(p => p.StringId == task.PolicePartyId);

                // 警察消失 → 转交
                if (pp == null || !pp.IsActive)
                {
                    CrimePool.EndTask(kvp.Key);
                    if (task.IsTargetValid()) Reassign(task.TargetCrime);
                    continue;
                }

                // 犯人消失（被其他国家摧毁等）→ 案件自动成功
                if (!task.IsTargetValid())
                {
                    RestoreAi(pp);
                    CrimePool.EndTask(kvp.Key);

                    string crimeName = task.TargetCrime?.CrimeType ?? "未知";
                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP 完成] 犯人已被消灭，案件（{crimeName}）自动结案",
                        Colors.Green));

                    PoliceResourceManager.StartResupply(pp);
                    continue;
                }

                // 押送中：由 OnTick 每帧处理距离检查，此处只保持警察移动方向
                if (task.IsEscortingPlayer)
                {
                    Settlement target = task.EscortSettlement;
                    if (target != null)
                        pp.SetMoveGoToSettlement(target, NavigationType.Default, false);
                    continue;
                }

                // 正常追击
                MobileParty criminal = task.TargetCrime.Offender;
                float dist = pp.GetPosition2D.Distance(criminal.GetPosition2D);

                // 对玩家用更远的宣战距离
                float warDist = criminal.IsMainParty ? WarDistancePlayer : WarDistance;

                // 声望 -1 到 -4 由纠察队对话系统处理，此处不宣战
                bool isPatrolRange = criminal.IsMainParty &&
                    PlayerBehaviorPool.Reputation >= -4 &&
                    PlayerBehaviorPool.Reputation <= -1;

                // 符合条件时对罪犯宣战
                if (!task.WarDeclared && dist < warDist && !isPatrolRange)
                {
                    DeclareWar(task, criminal);
                }

                try
                {
                    pp.SetMoveEngageParty(criminal, NavigationType.Default);
                }
                catch (Exception ex)
                {
                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP Error] 追击异常：{ex.Message}", Colors.Red));
                }
            }
        }

        private void DeclareWar(PoliceTask task, MobileParty criminal)
        {
            try
            {
                Clan policeClan = PoliceStats.GetPoliceClan();
                if (policeClan == null) return;

                Clan criminalClan = criminal.ActualClan;
                if (criminalClan == null) return;

                task.WarDeclared = true;

                // 野怪本来就敌对
                if (criminalClan.IsOutlaw && criminalClan.IsBanditFaction) return;

                IFaction target = criminalClan.MapFaction;
                if (target == null) return;

                // 不能对自己宣战
                if (target == policeClan || target == policeClan.MapFaction) return;

                task.WarTarget = target;

                if (!FactionManager.IsAtWarAgainstFaction(policeClan, target))
                {
                    FactionManager.DeclareWar(policeClan, target);
                }
            }
            catch (Exception ex)
            {
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP Error] 宣战失败：{ex.Message}", Colors.Red));
            }
        }

        #endregion

        #region 战斗结束

        private void OnMapEventEnded(MapEvent mapEvent)
        {
            if (mapEvent == null) return;
            if (!mapEvent.IsFieldBattle) return;

            foreach (var kvp in CrimePool.ActiveTasks.ToList())
            {
                var task = kvp.Value;
                if (!task.WarDeclared) continue;

                var pp = MobileParty.All.FirstOrDefault(p => p.StringId == task.PolicePartyId);

                // 警察全灭：检查犯人是否在这场战斗中
                if (pp == null)
                {
                    if (!InEvent(task.TargetCrime.Offender, mapEvent)) continue;

                    CrimePool.EndTask(kvp.Key);

                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP 失败] 警察部队阵亡，转交任务", Colors.Yellow));

                    Reassign(task.TargetCrime);
                    CrimePool.RefreshAccepting();
                    continue;
                }

                if (!InEvent(pp, mapEvent)) continue;
                if (!InEvent(task.TargetCrime.Offender, mapEvent)) continue;

                bool policeWon = IsOnWinningSide(pp, mapEvent);

                if (policeWon)
                {
                    // 玩家通缉：警察赢了 → 玩家被引擎正常俘虏 → 警察押送前往定居点
                    // OnTick 每帧检查距离，< 5f 时和平释放 + 惩罚
                    if (CrimePool.IsPlayerCrime(task.TargetCrime))
                    {
                        Settlement targetTown = FindNearestTown();
                        task.EscortSettlement = targetTown;
                        task.IsEscortingPlayer = true;
                        _hasActiveEscort = true;

                        if (targetTown != null)
                        {
                            pp.Ai.SetDoNotMakeNewDecisions(true);
                            pp.SetMoveGoToSettlement(targetTown, NavigationType.Default, false);
                        }

                        InformationManager.DisplayMessage(new InformationMessage(
                            $"[GWP] 你被 {pp.Name} 击败！正在被押送至 {(targetTown?.Name?.ToString() ?? "城镇")}...",
                            Colors.Yellow));

                        continue;
                    }

                    RestoreAi(pp);
                    CrimePool.EndTask(kvp.Key);

                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP 完成] {pp.Name} 击败 {task.TargetCrime.Offender.Name}",
                        Colors.Green));

                    PoliceResourceManager.StartResupply(pp);
                }
                else
                {
                    RestoreAi(pp);
                    CrimePool.EndTask(kvp.Key);

                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP 失败] {pp.Name} 被击败，转交任务",
                        Colors.Yellow));

                    Reassign(task.TargetCrime);
                    PoliceResourceManager.StartResupply(pp);
                }

                CrimePool.RefreshAccepting();
            }
        }

        private bool IsOnWinningSide(MobileParty police, MapEvent mapEvent)
        {
            if (!mapEvent.HasWinner) return false;

            foreach (var p in mapEvent.Winner.Parties)
            {
                if (p.Party?.IsMobile == true && p.Party.MobileParty == police)
                    return true;
            }

            return false;
        }

        /// <summary>
        /// 转交：优先找最近的空闲警察，其次找最近的在任警察
        /// </summary>
        private void Reassign(CrimeRecord crime)
        {
            if (!crime.IsOffenderValid()) return;

            Vec2 crimePos = crime.Offender.GetPosition2D;

            // 优先：最近的空闲且就绪的警察
            MobileParty bestFree = null;
            float bestFreeDist = float.MaxValue;
            foreach (var pp in PoliceStats.GetAllPoliceParties())
            {
                if (CrimePool.HasTask(pp.StringId)) continue;
                if (!PoliceResourceManager.IsReady(pp)) continue;

                float d = pp.GetPosition2D.Distance(crimePos);
                if (d < bestFreeDist) { bestFreeDist = d; bestFree = pp; }
            }

            if (bestFree != null)
            {
                BeginTask(bestFree, crime);
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP 接手] {bestFree.Name} 接手追捕 {crime.Offender.Name}",
                    Colors.Cyan));
                return;
            }

            // 其次：最近的在任警察，旧任务回池
            MobileParty bestBusy = null;
            string bestBusyKey = null;
            float bestBusyDist = float.MaxValue;
            foreach (var kvp in CrimePool.ActiveTasks.ToList())
            {
                if (kvp.Value.TargetCrime?.Offender?.StringId == crime.Offender.StringId) continue;
                var pp = MobileParty.All.FirstOrDefault(p => p.StringId == kvp.Value.PolicePartyId);
                if (pp == null || !pp.IsActive) continue;

                float d = pp.GetPosition2D.Distance(crimePos);
                if (d < bestBusyDist) { bestBusyDist = d; bestBusy = pp; bestBusyKey = kvp.Key; }
            }

            if (bestBusy != null)
            {
                var oldTask = CrimePool.GetTask(bestBusyKey);
                RestoreAi(bestBusy);

                if (oldTask != null && oldTask.IsTargetValid())
                    CrimePool.Return(oldTask.TargetCrime);

                CrimePool.EndTask(bestBusyKey);
                BeginTask(bestBusy, crime);

                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP 接手] {bestBusy.Name} 接手追捕 {crime.Offender.Name}",
                    Colors.Cyan));
                return;
            }

            // 全不可用：回池等补给完的警察自动接
            CrimePool.Return(crime);
        }

        private bool InEvent(MobileParty party, MapEvent me)
        {
            if (party == null || me == null) return false;

            foreach (var p in me.AttackerSide.Parties)
                if (p.Party?.IsMobile == true && p.Party.MobileParty == party) return true;
            foreach (var p in me.DefenderSide.Parties)
                if (p.Party?.IsMobile == true && p.Party.MobileParty == party) return true;

            return false;
        }

        #endregion

        #region 和平

        private void MakePeaceWithAllFactions()
        {
            IFaction playerFaction = Clan.PlayerClan?.MapFaction;
            if (playerFaction == null) return;

            Clan policeClan = PoliceStats.GetPoliceClan();
            if (policeClan != null && FactionManager.IsAtWarAgainstFaction(policeClan, playerFaction))
            {
                try { FactionManager.SetNeutral(policeClan, playerFaction); } catch { }
            }

            foreach (var victim in PlayerBehaviorPool.VictimFactions)
            {
                if (victim == null || victim == playerFaction) continue;
                if (!FactionManager.IsAtWarAgainstFaction(playerFaction, victim)) continue;

                try
                {
                    MakePeaceAction.Apply(playerFaction, victim);
                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP] 灰袍守卫调停：你与 {victim.Name} 恢复和平",
                        Colors.Green));
                }
                catch { }
            }

            PlayerBehaviorPool.ClearVictimFactions();
        }

        private Settlement FindNearestTown()
        {
            MobileParty player = MobileParty.MainParty;
            if (player == null) return null;

            Vec2 pos = player.GetPosition2D;
            Settlement best = null;
            float bestDist = float.MaxValue;

            foreach (Settlement s in Settlement.All)
            {
                if (!s.IsTown) continue;
                float d = pos.Distance(s.Position.ToVec2());
                if (d < bestDist) { bestDist = d; best = s; }
            }
            return best;
        }

        #endregion

        #region AI恢复

        private void RestoreAi(MobileParty police)
        {
            try
            {
                police.Ai.SetDoNotMakeNewDecisions(false);
                police.Ai.SetInitiative(0f, 0f, 0f);
            }
            catch { }
        }

        #endregion
    }
}
