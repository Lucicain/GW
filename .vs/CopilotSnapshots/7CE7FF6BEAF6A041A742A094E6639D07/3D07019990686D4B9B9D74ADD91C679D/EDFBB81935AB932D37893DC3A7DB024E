using System;
using System.Collections.Generic;
using System.Linq;
using Helpers;
using TaleWorlds.CampaignSystem;
using TaleWorlds.CampaignSystem.Actions;
using TaleWorlds.CampaignSystem.MapEvents;
using TaleWorlds.CampaignSystem.Party;
using TaleWorlds.CampaignSystem.Party.PartyComponents;
using TaleWorlds.CampaignSystem.Settlements;
using TaleWorlds.Core;
using TaleWorlds.Library;
using TaleWorlds.Localization;

namespace GreyWardenPolicePurity
{
    /// <summary>
    /// 灰袍纠察队系统（只负责声望 -1 到 -4 的罚款追讨）
    ///
    /// 与 PoliceEnforcementBehavior 使用完全相同的玩家处理机制：
    ///   战败/投降 → EndCaptivity → 传送到最近城镇 → 罚款 → 声望归零 → 和平
    /// </summary>
    public class PolicePatrolBehavior : CampaignBehaviorBase
    {
        private const int FinePerPoint = 100;
        private const int RewardPerPointPerDay = 20;
        private const int PatrolSize = 20;
        private const string PatrolIdPrefix = "gwp_patrol_";

        private readonly List<string> _activePatrolIds = new List<string>();
        private readonly List<string> _returningPatrolIds = new List<string>();

        private bool _fineAttempted = false;
        private bool _playerRefused = false;
        private Settlement _patrolOriginSettlement = null;

        public override void RegisterEvents()
        {
            CampaignEvents.DailyTickEvent.AddNonSerializedListener(this, OnDailyTick);
            CampaignEvents.HourlyTickEvent.AddNonSerializedListener(this, OnHourlyTick);
            CampaignEvents.MapEventEnded.AddNonSerializedListener(this, OnMapEventEnded);
        }

        public override void SyncData(IDataStore dataStore) { }

        #region 每日奖励

        private void OnDailyTick()
        {
            if (PlayerBehaviorPool.Reputation > 0)
            {
                int reward = PlayerBehaviorPool.Reputation * RewardPerPointPerDay;
                Hero.MainHero.ChangeHeroGold(reward);
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP] 灰袍守卫嘉奖：+{reward}金（声望{PlayerBehaviorPool.Reputation} × {RewardPerPointPerDay}）",
                    Colors.Green));
            }
        }

        #endregion

        #region 纠察队逻辑（-1到-4）

        private void OnHourlyTick()
        {
            CleanDeadPatrols();
            UpdateReturningPatrols();

            // 玩家拒绝后纠察队全部消失（战斗中被消灭、未触发OnMapEventEnded）→ 补扣声望
            if (_playerRefused && _activePatrolIds.Count == 0)
            {
                PlayerBehaviorPool.ChangeReputation(-5);
                CrimePool.TryAddPlayerCrime("抗拒执法",
                    MobileParty.MainParty?.GetPosition2D ?? Vec2.Zero,
                    "拒绝缴纳灰袍纠察队罚款");
                MakePeaceWithAllFactions();
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP] 拒绝执法！声望 -5，当前声望：{PlayerBehaviorPool.Reputation}",
                    Colors.Red));
                _playerRefused = false;
                _fineAttempted = false;
                return;
            }

            // 玩家拒绝后纠察队仍在追击/战斗中 → 等待战斗结束
            if (_playerRefused)
                return;

            int rep = PlayerBehaviorPool.Reputation;

            // 只在 -1 到 -4 范围内工作
            if (rep >= 0 || rep <= -5)
            {
                if (_activePatrolIds.Count > 0)
                    ReturnAllPatrols();
                return;
            }

            // 生成纠察队
            if (_activePatrolIds.Count == 0)
            {
                SpawnPatrol();
                _fineAttempted = false;
            }

            // 追击玩家
            foreach (string patrolId in _activePatrolIds.ToList())
            {
                var patrol = MobileParty.All.FirstOrDefault(p => p.StringId == patrolId);
                if (patrol == null || !patrol.IsActive) continue;

                MobileParty player = MobileParty.MainParty;
                if (player == null || !player.IsActive) continue;

                patrol.SetMoveGoToPoint(
                    new CampaignVec2(player.GetPosition2D, true),
                    MobileParty.NavigationType.Default);

                float dist = patrol.GetPosition2D.Distance(player.GetPosition2D);
                if (dist < 3f && !_fineAttempted)
                {
                    ShowFineDialog(patrol);
                }
            }
        }

        private void SpawnPatrol()
        {
            Clan policeClan = PoliceStats.GetPoliceClan();
            if (policeClan == null) return;

            _patrolOriginSettlement = FindNearestTown(MobileParty.MainParty);
            if (_patrolOriginSettlement == null) return;

            string patrolId = PatrolIdPrefix + MBRandom.RandomInt(10000, 99999);

            try
            {
                MobileParty patrol = CustomPartyComponent.CreateCustomPartyWithPartyTemplate(
                    _patrolOriginSettlement.GatePosition,
                    1f,
                    _patrolOriginSettlement,
                    new TextObject("灰袍纠察队"),
                    policeClan,
                    policeClan.DefaultPartyTemplate,
                    policeClan.Leader,
                    "", "",
                    5f,
                    false);

                patrol.StringId = patrolId;
                patrol.ActualClan = policeClan;

                patrol.MemberRoster.Clear();
                FillPatrolTroops(patrol);

                patrol.Ai.SetDoNotMakeNewDecisions(true);
                patrol.Ai.SetInitiative(1f, 0f, 999f);

                _activePatrolIds.Add(patrolId);

                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP] 灰袍纠察队从 {_patrolOriginSettlement.Name} 出发追讨罚款！",
                    Colors.Yellow));
            }
            catch { }
        }

        private void FillPatrolTroops(MobileParty patrol)
        {
            if (patrol == null) return;

            CharacterObject infantry = CharacterObject.Find("gwheavyinfantry");
            CharacterObject archer = CharacterObject.Find("gwarcher");

            if (infantry != null && archer != null)
            {
                int infantryCount = (int)(PatrolSize * 0.6f);
                int archerCount = PatrolSize - infantryCount;
                patrol.MemberRoster.AddToCounts(infantry, infantryCount);
                patrol.MemberRoster.AddToCounts(archer, archerCount);
            }
            else if (infantry != null)
            {
                patrol.MemberRoster.AddToCounts(infantry, PatrolSize);
            }
            else if (archer != null)
            {
                patrol.MemberRoster.AddToCounts(archer, PatrolSize);
            }
        }

        #endregion

        #region 罚款对话

        private void ShowFineDialog(MobileParty patrol)
        {
            if (_fineAttempted) return;
            _fineAttempted = true;

            int rep = PlayerBehaviorPool.Reputation;
            if (rep >= 0) return;

            int fine = Math.Abs(rep) * FinePerPoint;
            int playerGold = Hero.MainHero.Gold;

            string dialogText = $"站住！灰袍纠察队在此执法。\n" +
                $"你当前有 {Math.Abs(rep)} 次违规记录，需缴纳罚款 {fine} 金。\n" +
                (playerGold >= fine
                    ? $"你身上有 {playerGold} 金，足够缴纳。"
                    : $"你身上只有 {playerGold} 金，不足以缴纳全部罚款，将尽数收取。");

            InformationManager.ShowInquiry(new InquiryData(
                "灰袍纠察队",
                dialogText,
                true,
                true,
                "缴纳罚款",
                "拒绝缴纳",
                () => OnAcceptFine(fine),
                () => OnRefuseFine(patrol)),
                true);
        }

        private void OnAcceptFine(int fine)
        {
            CollectFine(fine);
            PlayerBehaviorPool.ResetReputation(0);
            MakePeaceWithAllFactions();
            ReturnAllPatrols();
        }

        private void OnRefuseFine(MobileParty patrol)
        {
            _playerRefused = true;

            InformationManager.DisplayMessage(new InformationMessage(
                $"[GWP] 你拒绝缴纳罚款！纠察队将使用武力执法！",
                Colors.Red));

            Clan policeClan = PoliceStats.GetPoliceClan();
            if (policeClan != null)
            {
                IFaction playerFaction = Clan.PlayerClan?.MapFaction;
                if (playerFaction != null && !FactionManager.IsAtWarAgainstFaction(policeClan, playerFaction))
                {
                    try { FactionManager.DeclareWar(policeClan, playerFaction); } catch { }
                }
            }

            if (patrol != null && patrol.IsActive)
            {
                patrol.SetMoveEngageParty(MobileParty.MainParty, MobileParty.NavigationType.Default);
            }
        }

        #endregion

        #region 战斗结束

        private void OnMapEventEnded(MapEvent mapEvent)
        {
            try
            {
                if (mapEvent == null) return;

                // 判断纠察队和玩家是否参与了本次战斗
                bool patrolInvolved = false;
                bool playerInvolved = false;

                foreach (var p in mapEvent.InvolvedParties)
                {
                    if (p?.MobileParty == null) continue;
                    if (IsPatrol(p.MobileParty)) patrolInvolved = true;
                    if (p.MobileParty.IsMainParty) playerInvolved = true;
                }

                if (!patrolInvolved || !playerInvolved) return;

                // 判断谁赢了
                bool patrolWon = false;
                if (mapEvent.HasWinner && mapEvent.Winner != null)
                {
                    // 方法1：检查纠察队是否在胜方
                    foreach (var p in mapEvent.Winner.Parties)
                    {
                        if (p?.Party?.IsMobile == true && IsPatrol(p.Party.MobileParty))
                        {
                            patrolWon = true;
                            break;
                        }
                    }

                    // 方法2：如果方法1没找到纠察队，检查玩家是否在败方（投降时纠察队可能已不在Winner中）
                    if (!patrolWon)
                    {
                        var loser = (mapEvent.Winner == mapEvent.AttackerSide)
                            ? mapEvent.DefenderSide
                            : mapEvent.AttackerSide;
                        if (loser != null)
                        {
                            foreach (var p in loser.Parties)
                            {
                                if (p?.Party?.IsMobile == true && p.Party.MobileParty.IsMainParty)
                                {
                                    patrolWon = true;
                                    break;
                                }
                            }
                        }
                    }
                }

                if (patrolWon)
                {
                    // ============================
                    // 纠察队胜利（玩家投降/战败）
                    // 与 PoliceEnforcementBehavior.HandlePlayerCapturedByPolice 完全相同的机制
                    // ============================
                    HandlePlayerCapturedByPatrol();
                }
                else
                {
                    // 玩家胜利 → 声望-5，进入通缉池
                    OnPlayerVictory();
                    // 玩家胜利后也要和平（纠察队已被击败）
                    MakePeaceWithAllFactions();
                }

                // 清理并返回所有纠察队
                CleanDeadPatrols();
                ReturnAllPatrols();
                _playerRefused = false;
            }
            catch (Exception ex)
            {
                // 异常保护：确保不崩溃，并强制清理状态
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP Error] 纠察队战斗处理异常：{ex.Message}", Colors.Red));
                try { MakePeaceWithAllFactions(); } catch { }
                try { CleanDeadPatrols(); } catch { }
                try { ReturnAllPatrols(); } catch { }
                _playerRefused = false;
            }
        }

        /// <summary>
        /// 纠察队击败玩家后的处理
        /// 与 PoliceEnforcementBehavior.HandlePlayerCapturedByPolice 完全相同的机制：
        /// 释放俘虏 → 传送到城镇 → 罚款 → 声望清零 → 和平
        /// </summary>
        private void HandlePlayerCapturedByPatrol()
        {
            // 1. 如果引擎自动把玩家设为俘虏了，先释放
            if (PlayerCaptivity.IsCaptive)
            {
                try { PlayerCaptivity.EndCaptivity(); } catch { }
            }

            // 2. 传送到最近城镇（优先用纠察队出发的定居点）
            Settlement nearestTown = _patrolOriginSettlement ?? FindNearestTown(MobileParty.MainParty);
            if (nearestTown != null)
            {
                try
                {
                    TeleportHeroAction.ApplyImmediateTeleportToSettlement(
                        Hero.MainHero, nearestTown);
                }
                catch { }
            }

            // 3. 罚款
            int rep = PlayerBehaviorPool.Reputation;
            int fine = Math.Abs(rep) * FinePerPoint;
            CollectFine(fine);

            // 4. 声望归零
            PlayerBehaviorPool.ResetReputation(0);

            // 5. 与警察+所有受害国和平
            MakePeaceWithAllFactions();

            // 6. 显示消息
            string townName = nearestTown?.Name?.ToString() ?? "最近城镇";
            InformationManager.DisplayMessage(new InformationMessage(
                $"[GWP] 你被纠察队抓获，押送至 {townName}，缴纳罚款 {fine} 金，声望已清零",
                Colors.Yellow));
        }

        private void OnPlayerVictory()
        {
            PlayerBehaviorPool.ChangeReputation(-5);
            CrimePool.TryAddPlayerCrime("抗拒执法",
                MobileParty.MainParty?.GetPosition2D ?? Vec2.Zero,
                _playerRefused ? "拒绝缴纳灰袍纠察队罚款" : "攻击灰袍纠察队");

            InformationManager.DisplayMessage(new InformationMessage(
                $"[GWP] 击败纠察队！声望 -5，当前声望：{PlayerBehaviorPool.Reputation}，警察部队已介入！",
                Colors.Red));
        }

        #endregion

        #region 罚款收取

        private void CollectFine(int fine)
        {
            int playerGold = Hero.MainHero.Gold;

            if (playerGold >= fine)
            {
                Hero.MainHero.ChangeHeroGold(-fine);
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP] 灰袍纠察队收取罚款：{fine}金",
                    Colors.Yellow));
            }
            else
            {
                if (playerGold > 0)
                    Hero.MainHero.ChangeHeroGold(-playerGold);
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP] 灰袍纠察队收取罚款：{playerGold}金（应缴{fine}金，已尽数缴纳）",
                    Colors.Yellow));
            }
        }

        #endregion

        #region 辅助

        private bool IsPatrol(MobileParty party)
        {
            if (party == null) return false;
            return party.StringId != null && party.StringId.StartsWith(PatrolIdPrefix);
        }

        /// <summary>
        /// 恢复和平：警察势力 + 所有受害国
        /// </summary>
        private void MakePeaceWithAllFactions()
        {
            IFaction playerFaction = Clan.PlayerClan?.MapFaction;
            if (playerFaction == null) return;

            // 与警察势力和平
            Clan policeClan = PoliceStats.GetPoliceClan();
            if (policeClan != null && FactionManager.IsAtWarAgainstFaction(policeClan, playerFaction))
            {
                try { FactionManager.SetNeutral(policeClan, playerFaction); } catch { }
            }

            // 与所有受害国和平
            foreach (var victim in PlayerBehaviorPool.VictimFactions)
            {
                if (victim == null || victim == playerFaction) continue;
                if (!FactionManager.IsAtWarAgainstFaction(playerFaction, victim)) continue;

                try
                {
                    MakePeaceAction.Apply(playerFaction, victim);
                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP] 灰袍守卫调停：你与 {victim.Name} 恢复和平",
                        Colors.Green));
                }
                catch { }
            }

            PlayerBehaviorPool.ClearVictimFactions();
        }

        /// <summary>
        /// 让所有活跃纠察队返回出发定居点（到达后销毁）
        /// </summary>
        private void ReturnAllPatrols()
        {
            foreach (string id in _activePatrolIds.ToList())
            {
                var patrol = MobileParty.All.FirstOrDefault(p => p.StringId == id);
                if (patrol != null && patrol.IsActive)
                {
                    patrol.Ai.SetDoNotMakeNewDecisions(true);
                    Settlement town = _patrolOriginSettlement ?? FindNearestTown(patrol);
                    if (town != null)
                    {
                        patrol.SetMoveGoToSettlement(town, MobileParty.NavigationType.Default, false);
                        _returningPatrolIds.Add(id);
                    }
                    else
                    {
                        try { DestroyPartyAction.Apply(null, patrol); } catch { }
                    }
                }
            }
            _activePatrolIds.Clear();
            _fineAttempted = false;
        }

        /// <summary>
        /// 检查返回中的纠察队是否到达定居点，到达则销毁
        /// </summary>
        private void UpdateReturningPatrols()
        {
            for (int i = _returningPatrolIds.Count - 1; i >= 0; i--)
            {
                string id = _returningPatrolIds[i];
                var patrol = MobileParty.All.FirstOrDefault(p => p.StringId == id);

                if (patrol == null || !patrol.IsActive)
                {
                    _returningPatrolIds.RemoveAt(i);
                    continue;
                }

                Settlement target = _patrolOriginSettlement ?? FindNearestTown(patrol);
                if (target != null)
                {
                    float dist = patrol.GetPosition2D.Distance(target.Position.ToVec2());
                    if (dist < 3f)
                    {
                        try { DestroyPartyAction.Apply(null, patrol); } catch { }
                        _returningPatrolIds.RemoveAt(i);
                    }
                }
            }
        }

        private void CleanDeadPatrols()
        {
            _activePatrolIds.RemoveAll(id =>
            {
                var p = MobileParty.All.FirstOrDefault(x => x.StringId == id);
                return p == null || !p.IsActive;
            });

            _returningPatrolIds.RemoveAll(id =>
            {
                var p = MobileParty.All.FirstOrDefault(x => x.StringId == id);
                return p == null || !p.IsActive;
            });
        }

        private Settlement FindNearestTown(MobileParty party)
        {
            if (party == null) return null;

            Vec2 pos = party.GetPosition2D;
            Settlement best = null;
            float bestDist = float.MaxValue;

            foreach (Settlement s in Settlement.All)
            {
                if (!s.IsTown) continue;
                float d = pos.Distance(s.Position.ToVec2());
                if (d < bestDist) { bestDist = d; best = s; }
            }
            return best;
        }

        #endregion
    }
}
