using System;
using System.Collections.Generic;
using System.Linq;
using System.Reflection;
using TaleWorlds.CampaignSystem;
using TaleWorlds.CampaignSystem.MapEvents;
using TaleWorlds.CampaignSystem.Party;
using TaleWorlds.Core;
using TaleWorlds.Library;
using TaleWorlds.Localization;
using TaleWorlds.ObjectSystem;
using static TaleWorlds.CampaignSystem.Party.MobileParty;

namespace GreyWardenPolicePurity
{
    /// <summary>
    /// 警察惩戒系统 - 通缉者家族方案
    /// 
    /// 核心逻辑：
    /// 1. 创建虚拟通缉者家族（wanted_clan）
    /// 2. 警察永久与通缉者家族战争
    /// 3. 接案时：将罪犯部队转移到通缉者家族
    /// 4. 直接追击：不等待，不分阶段，立即出警
    /// 5. 战斗结束：将罪犯送回原家族
    /// </summary>
    public class PoliceEnforcementBehavior : CampaignBehaviorBase
    {
        private const string PoliceClanId = "gw";
        private const string WantedClanId = "gwp_wanted_clan";

        // 犯罪任务池（保留24小时）
        private List<CrimeRecord> _crimePool = new List<CrimeRecord>();

        // 活跃任务（警察PartyId -> 任务）
        private Dictionary<string, PoliceTask> _activeTasks = new Dictionary<string, PoliceTask>();

        // 通缉者家族引用
        private Clan _wantedClan;

        public override void RegisterEvents()
        {
            // 游戏加载后初始化
            CampaignEvents.OnGameLoadedEvent.AddNonSerializedListener(this, OnGameLoaded);

            // 订阅犯罪通知
            PoliceCrimeMonitorEnhanced.OnCrimeDetected += HandleCrimeDetected;

            // 战斗结束
            CampaignEvents.MapEventEnded.AddNonSerializedListener(this, OnMapEventEnded);

            // 每小时：警察接案 + 任务监控
            CampaignEvents.HourlyTickEvent.AddNonSerializedListener(this, OnHourlyTick);

            // 每日清理
            CampaignEvents.DailyTickEvent.AddNonSerializedListener(this, OnDailyTick);
        }

        public override void SyncData(IDataStore dataStore) { }

        #region 初始化

        private void OnGameLoaded(CampaignGameStarter starter)
        {
            // 确保通缉者家族存在
            EnsureWantedClanExists();

            // 确保警察与通缉者家族战争
            EnsureWarWithWantedClan();
        }

        /// <summary>
        /// 确保通缉者家族存在（运行时创建）
        /// </summary>
        private void EnsureWantedClanExists()
        {
            // 查找是否已存在
            _wantedClan = Clan.All.FirstOrDefault(c => c.StringId == WantedClanId);

            if (_wantedClan == null)
            {
                try
                {
                    // 用MBObjectManager创建Clan对象
                    _wantedClan = MBObjectManager.Instance.CreateObject<Clan>(WantedClanId);

                    // 用公开API设置名称
                    var name = new TextObject("Wanted Criminals");
                    _wantedClan.ChangeClanName(name, name);

                    // IsOutlaw/IsBanditFaction没有setter，通过backing field设置
                    SetBackingField(_wantedClan, "<IsOutlaw>k__BackingField", true);
                    SetBackingField(_wantedClan, "<IsBanditFaction>k__BackingField", true);

                    // 调用InitMembers初始化内部列表
                    var initMethod = typeof(Clan).GetMethod("InitMembers",
                        BindingFlags.NonPublic | BindingFlags.Instance);
                    initMethod?.Invoke(_wantedClan, null);

                    InformationManager.DisplayMessage(new InformationMessage(
                        "[GWP] 通缉者家族已创建",
                        Colors.Green
                    ));
                }
                catch (Exception ex)
                {
                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP Error] 创建通缉者家族失败：{ex.Message}",
                        Colors.Red
                    ));
                }
            }
        }

        /// <summary>
        /// 通过backing field设置只读属性
        /// </summary>
        private static void SetBackingField(object obj, string fieldName, object value)
        {
            var field = obj.GetType().GetField(fieldName,
                BindingFlags.NonPublic | BindingFlags.Instance);
            field?.SetValue(obj, value);
        }

        /// <summary>
        /// 确保警察与通缉者家族永久战争
        /// </summary>
        private void EnsureWarWithWantedClan()
        {
            if (_wantedClan == null) return;

            Clan policeClan = GetPoliceClan();
            if (policeClan == null) return;

            // 检查是否已经是敌对
            if (!FactionManager.IsAtWarAgainstFaction(policeClan, _wantedClan))
            {
                try
                {
                    FactionManager.DeclareWar(policeClan, _wantedClan);

                    InformationManager.DisplayMessage(new InformationMessage(
                        "[GWP] 警察与通缉者家族进入永久战争状态",
                        Colors.Yellow
                    ));
                }
                catch (Exception ex)
                {
                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP Error] 宣战失败：{ex.Message}",
                        Colors.Red
                    ));
                }
            }
        }

        #endregion

        #region 犯罪通知处理

        private void HandleCrimeDetected(string crimeType, MobileParty offender, Vec2 location, string victimName)
        {
            if (offender == null || !offender.IsActive) return;

            // 检查是否已存在
            if (_crimePool.Any(c => c.Offender != null && c.Offender.StringId == offender.StringId))
            {
                return;
            }

            var crime = new CrimeRecord
            {
                CrimeId = GenerateUniqueId(),
                CrimeType = crimeType,
                Offender = offender,
                OccurredTime = CampaignTime.Now,
                Location = location,
                VictimName = victimName
            };

            _crimePool.Add(crime);

            // 显示入池消息
            int validCount = _crimePool.Count(c => c.IsOffenderValid());
            string clanName = offender.ActualClan?.Name?.ToString() ?? "未知";

            InformationManager.DisplayMessage(new InformationMessage(
                $"[GWP 通缉] {crimeType} | 罪犯={offender.Name?.ToString()}（{clanName}）| 池中案件={validCount}",
                Colors.Yellow
            ));
        }

        #endregion

        #region 警察接案（简化版）

        private void OnHourlyTick()
        {
            AssignTasksToPolice();
            UpdateActiveTasks();
        }

        private void AssignTasksToPolice()
        {
            Clan policeClan = GetPoliceClan();
            if (policeClan == null) return;

            // 关键：不等待，有案件就接
            int pendingCrimes = _crimePool.Count(c => c.IsOffenderValid());
            if (pendingCrimes == 0) return;

            foreach (var component in policeClan.WarPartyComponents)
            {
                if (component == null) continue;

                MobileParty policeParty = component.MobileParty;
                if (policeParty == null || !policeParty.IsActive) continue;

                // 检查是否已有任务
                if (IsPoliceOnTask(policeParty)) continue;

                // 选择最近的犯罪
                CrimeRecord nearestCrime = GetNearestCrime(policeParty.GetPosition2D);
                if (nearestCrime == null) continue;

                // 立即接案
                AssignTask(policeParty, nearestCrime);
            }
        }

        private CrimeRecord GetNearestCrime(Vec2 position)
        {
            CrimeRecord nearest = null;
            float minDistance = float.MaxValue;

            foreach (var crime in _crimePool)
            {
                if (!crime.IsOffenderValid()) continue;

                float distance = position.Distance(crime.Offender.GetPosition2D);

                if (distance < minDistance)
                {
                    minDistance = distance;
                    nearest = crime;
                }
            }

            return nearest;
        }

        private bool IsPoliceOnTask(MobileParty police)
        {
            return _activeTasks.ContainsKey(police.StringId);
        }

        private void AssignTask(MobileParty police, CrimeRecord crime)
        {
            // 记录原家族
            Clan originalClan = crime.Offender.ActualClan;

            var task = new PoliceTask
            {
                TaskId = GenerateUniqueId(),
                PolicePartyId = police.StringId,
                TargetCrime = crime,
                AssignedTime = CampaignTime.Now,
                Status = TaskStatus.InProgress,
                OriginalClan = originalClan
            };

            _activeTasks[police.StringId] = task;

            // 从池子移除
            _crimePool.Remove(crime);

            // 关键：将罪犯转移到通缉者家族
            TransferToWantedClan(crime.Offender, originalClan);

            // 直接开始追击
            SetPoliceChaseTarget(police, crime.Offender);

            float distance = police.GetPosition2D.Distance(crime.Offender.GetPosition2D);

            InformationManager.DisplayMessage(new InformationMessage(
                $"[GWP 出警] {police.Name?.ToString()} → {crime.Offender.Name?.ToString()} | {crime.CrimeType} | 距离={distance:F0}",
                Colors.Cyan
            ));
        }

        /// <summary>
        /// 将罪犯部队转移到通缉者家族
        /// </summary>
        private void TransferToWantedClan(MobileParty criminal, Clan originalClan)
        {
            if (_wantedClan == null || criminal == null) return;

            try
            {
                // ActualClan有公开setter，直接赋值
                criminal.ActualClan = _wantedClan;

                string originalName = originalClan?.Name?.ToString() ?? "未知";
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP 通缉] {criminal.Name?.ToString()} 已被列入通缉名单（原家族：{originalName}）",
                    Colors.Yellow
                ));
            }
            catch (Exception ex)
            {
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP Error] 转移到通缉者家族失败：{ex.Message}",
                    Colors.Red
                ));
            }
        }

        #endregion

        #region AI控制

        private void SetPoliceChaseTarget(MobileParty police, MobileParty target)
        {
            try
            {
                // 设置追击目标
                police.SetMoveEngageParty(target, NavigationType.Default);

                // 锁定AI决策，防止中途改变目标
                police.Ai.SetDoNotMakeNewDecisions(true);

                // 最大攻击积极性（攻击=1, 回避=0, 持续12小时）
                police.Ai.SetInitiative(1f, 0f, 12f);
            }
            catch (Exception ex)
            {
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP Error] 设置追击失败：{ex.Message}",
                    Colors.Red
                ));
            }
        }

        private void RestorePoliceNormalBehavior(MobileParty police)
        {
            try
            {
                // 恢复AI自主决策
                police.Ai.SetDoNotMakeNewDecisions(false);

                // 恢复默认积极性
                police.Ai.SetInitiative(0f, 0f, 0f);
            }
            catch { }
        }

        #endregion

        #region 任务监控

        private void UpdateActiveTasks()
        {
            var tasksToRemove = new List<string>();

            foreach (var kvp in _activeTasks)
            {
                var task = kvp.Value;

                var policeParty = MobileParty.All.FirstOrDefault(p => p.StringId == task.PolicePartyId);

                if (policeParty == null || !policeParty.IsActive)
                {
                    tasksToRemove.Add(kvp.Key);
                    continue;
                }

                // 目标有效性检查
                if (!task.IsTargetValid())
                {
                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP 失效] 目标消失，{policeParty.Name?.ToString()} 任务取消",
                        Colors.Yellow
                    ));
                    CancelTask(policeParty, task);
                    tasksToRemove.Add(kvp.Key);
                    continue;
                }

                // 超时检查（12小时）
                if (task.IsHuntingExpired(CampaignTime.Now))
                {
                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP 超时] {policeParty.Name?.ToString()} 追捕超时（12H），任务取消",
                        Colors.Yellow
                    ));
                    CancelTask(policeParty, task);
                    tasksToRemove.Add(kvp.Key);
                    continue;
                }

                // 每小时刷新追击指令
                SetPoliceChaseTarget(policeParty, task.TargetCrime.Offender);
            }

            foreach (var key in tasksToRemove)
            {
                _activeTasks.Remove(key);
            }
        }

        private void CancelTask(MobileParty police, PoliceTask task)
        {
            task.Status = TaskStatus.Cancelled;
            RestorePoliceNormalBehavior(police);

            // 关键：将罪犯送回原家族
            if (task.TargetCrime != null)
            {
                RestoreToOriginalClan(task.TargetCrime.Offender, task.OriginalClan);
            }
        }

        #endregion

        #region 战斗监听

        private void OnMapEventEnded(MapEvent mapEvent)
        {
            if (mapEvent == null) return;

            foreach (var kvp in _activeTasks.ToList())
            {
                var task = kvp.Value;
                var policeParty = MobileParty.All.FirstOrDefault(p => p.StringId == task.PolicePartyId);

                if (policeParty == null) continue;

                bool policeInvolved = IsPartyInMapEvent(policeParty, mapEvent);
                if (!policeInvolved) continue;

                bool targetInvolved = IsPartyInMapEvent(task.TargetCrime.Offender, mapEvent);
                if (!targetInvolved) continue;

                CompleteTask(policeParty, task, mapEvent);
            }
        }

        private bool IsPartyInMapEvent(MobileParty party, MapEvent mapEvent)
        {
            if (party == null || mapEvent == null) return false;

            foreach (var mapEventParty in mapEvent.AttackerSide.Parties)
            {
                if (mapEventParty.Party != null &&
                    mapEventParty.Party.IsMobile &&
                    mapEventParty.Party.MobileParty == party)
                    return true;
            }

            foreach (var mapEventParty in mapEvent.DefenderSide.Parties)
            {
                if (mapEventParty.Party != null &&
                    mapEventParty.Party.IsMobile &&
                    mapEventParty.Party.MobileParty == party)
                    return true;
            }

            return false;
        }

        private void CompleteTask(MobileParty police, PoliceTask task, MapEvent mapEvent)
        {
            task.Status = TaskStatus.Completed;

            string result = mapEvent.Winner != null ? "胜利" : "战斗结束";

            InformationManager.DisplayMessage(new InformationMessage(
                $"[GWP 完成] 罪犯已伏法！{task.TargetCrime.Offender.Name?.ToString()} | {task.TargetCrime.CrimeType} | {result}",
                Colors.Green
            ));

            // 关键：将罪犯送回原家族
            RestoreToOriginalClan(task.TargetCrime.Offender, task.OriginalClan);

            _activeTasks.Remove(task.PolicePartyId);
            RestorePoliceNormalBehavior(police);
        }

        /// <summary>
        /// 将罪犯送回原家族
        /// </summary>
        private void RestoreToOriginalClan(MobileParty criminal, Clan originalClan)
        {
            if (criminal == null || !criminal.IsActive || originalClan == null) return;

            try
            {
                // ActualClan有公开setter，直接赋值
                criminal.ActualClan = originalClan;

                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP 恢复] {criminal.Name?.ToString()} 已送回原家族（{originalClan.Name}）",
                    Colors.Cyan
                ));
            }
            catch (Exception ex)
            {
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP Error] 送回原家族失败：{ex.Message}",
                    Colors.Red
                ));
            }
        }

        #endregion

        #region 定期清理

        private void OnDailyTick()
        {
            var expiredCrimes = _crimePool.Where(c => c.IsExpired(CampaignTime.Now)).ToList();

            foreach (var crime in expiredCrimes)
            {
                _crimePool.Remove(crime);
            }

            if (expiredCrimes.Count > 0)
            {
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP 清理] 已清理 {expiredCrimes.Count} 个过期案件（24小时）",
                    Colors.Gray
                ));
            }
        }

        #endregion

        #region 辅助方法

        private string GenerateUniqueId()
        {
            long timestamp = (long)CampaignTime.Now.ToHours;
            int random = MBRandom.RandomInt(1000, 9999);
            return $"CRIME_{timestamp}_{random}";
        }

        private Clan GetPoliceClan()
        {
            return Clan.FindFirst(c =>
                string.Equals(c.StringId, PoliceClanId, StringComparison.OrdinalIgnoreCase));
        }

        #endregion
    }
}