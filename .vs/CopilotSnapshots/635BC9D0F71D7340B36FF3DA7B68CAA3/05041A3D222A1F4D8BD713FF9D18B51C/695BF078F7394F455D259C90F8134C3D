$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')

# Find the behavior that makes clans join kingdoms
Write-Host "=== ALL behaviors with methods matching Join/Vassal/Defect/Pledge ==="
$types = $a.GetTypes()
foreach ($t in $types) {
    $methods = $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance -bor [Reflection.BindingFlags]::Static)
    $found = $false
    foreach ($m in $methods) {
        if ($m.DeclaringType -eq $t -and ($m.Name -match 'ConsiderJoin|JoinAsVassal|DecideToJoin|ClanDecision|TryJoin|EvaluateJoin|JoinKingdom(?!Action)|ClanJoin|ConsiderDefect|PledgeAllegiance')) {
            if (-not $found) {
                Write-Host "  $($t.Name):"
                $found = $true
            }
            $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
            Write-Host "    $($m.Name)($params)"
        }
    }
}

# Check ClanPoliticsModel or similar
Write-Host ""
Write-Host "=== Models matching ClanPolitics/ClanDecision ==="
foreach ($t in $types) {
    if ($t.Name -match 'ClanPolitics|ClanDecision|VassalAndMerc') {
        Write-Host "  $($t.FullName)"
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Instance)) {
            if ($m.DeclaringType -eq $t) {
                Write-Host "    $($m.Name)"
            }
        }
    }
}

# Check if ChangeKingdomAction.ApplyByJoinToKingdom checks IsMinorFaction or IsNoble
Write-Host ""
Write-Host "=== ChangeKingdomAction ALL methods ==="
$cka = $a.GetType('TaleWorlds.CampaignSystem.Actions.ChangeKingdomAction')
foreach ($m in $cka.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
    if ($m.DeclaringType -eq $cka) {
        $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  $($m.Name)($params)"
    }
}

# Who calls ApplyByJoinToKingdom?
Write-Host ""
Write-Host "=== Behaviors that mention 'JoinToKingdom' or 'ApplyByJoin' ==="
foreach ($t in $types) {
    if ($t.IsClass -and -not $t.IsAbstract) {
        $methods = $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)
        foreach ($m in $methods) {
            if ($m.DeclaringType -eq $t -and $m.Name -match 'ConsiderClanJoin|MakeClanJoin|HandleClanJoin|ClanPolitics') {
                Write-Host "  $($t.Name).$($m.Name)"
            }
        }
    }
}
