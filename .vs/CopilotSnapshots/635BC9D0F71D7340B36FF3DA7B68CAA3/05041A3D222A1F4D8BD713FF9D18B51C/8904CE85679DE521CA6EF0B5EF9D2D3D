$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')

# 1. ClanVariablesCampaignBehavior - the main clan AI behavior
Write-Host "=== ClanVariablesCampaignBehavior - all methods ==="
$cvb = $a.GetType('TaleWorlds.CampaignSystem.CampaignBehaviors.ClanVariablesCampaignBehavior')
foreach ($m in $cvb.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)) {
    if ($m.DeclaringType -eq $cvb -and ($m.Name -match 'Kingdom|Join|Vassal|Merc|Defect|Pledge')) {
        $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  $($m.Name)($params)"
    }
}

# 2. Search all behaviors for JoinKingdom / Vassal / Mercenary recruitment logic
Write-Host ""
Write-Host "=== Behaviors with Join/Vassal/Recruit logic ==="
$types = $a.GetTypes()
foreach ($t in $types) {
    if ($t.Name -like '*CampaignBehavior*' -or $t.Name -like '*Behavior*') {
        $methods = $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)
        foreach ($m in $methods) {
            if ($m.DeclaringType -eq $t -and ($m.Name -match 'JoinKingdom|RecruitClan|HireMerc|OfferVassal|ConsiderJoin|DecideKingdom')) {
                $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                Write-Host "  $($t.Name).$($m.Name)($params)"
            }
        }
    }
}

# 3. JoinKingdomAction or similar
Write-Host ""
Write-Host "=== Actions related to joining kingdom ==="
foreach ($t in $types) {
    if ($t.Name -like '*JoinKingdom*' -or ($t.Namespace -like '*Actions*' -and $t.Name -match 'Kingdom|Vassal|Mercenary')) {
        Write-Host "  $($t.FullName)"
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
            if ($m.DeclaringType -eq $t) {
                $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                Write-Host "    $($m.Name)($params)"
            }
        }
    }
}

# 4. DefaultDiplomacyModel - score for joining
Write-Host ""
Write-Host "=== DefaultDiplomacyModel - join/mercenary score ==="
$ddm = $a.GetType('TaleWorlds.CampaignSystem.GameComponents.DefaultDiplomacyModel')
if ($ddm) {
    foreach ($m in $ddm.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Instance)) {
        if ($m.DeclaringType -eq $ddm -and ($m.Name -match 'Score.*Join|Score.*Merc|Score.*Vassal|Score.*Kingdom|Clan.*Join')) {
            $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
            Write-Host "  $($m.Name)($params)"
        }
    }
}

# 5. DiplomacyModel base
Write-Host ""
Write-Host "=== DiplomacyModel - all Join/Merc related ==="
$dm = $a.GetType('TaleWorlds.CampaignSystem.ComponentInterfaces.DiplomacyModel')
if ($dm) {
    foreach ($m in $dm.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Instance)) {
        if ($m.DeclaringType -eq $dm -and ($m.Name -match 'Score|Merc|Vassal|Join|Clan')) {
            $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
            Write-Host "  $($m.Name)($params)"
        }
    }
}
