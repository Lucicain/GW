$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')

# Find DiplomaticBartersBehavior with correct namespace
Write-Host "=== Finding DiplomaticBartersBehavior ==="
$types = $a.GetTypes()
foreach ($t in $types) {
    if ($t.Name -eq 'DiplomaticBartersBehavior') {
        Write-Host "Found: $($t.FullName)"
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)) {
            if ($m.DeclaringType -eq $t) {
                $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                Write-Host "  $($m.Name)($params)"
            }
        }
    }
}

# VassalAndMercenaryOffer - key methods
Write-Host ""
Write-Host "=== VassalKingdomSelectionConditionsHold / MercenaryKingdomSelectionConditionsHold ==="
Write-Host "(These methods determine which clans can receive offers)"
$vmo = $a.GetType('TaleWorlds.CampaignSystem.CampaignBehaviors.VassalAndMercenaryOfferCampaignBehavior')
$m1 = $vmo.GetMethod('VassalKingdomSelectionConditionsHold', [Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)
if ($m1) {
    $params = ($m1.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
    Write-Host "  $($m1.ReturnType.Name) VassalKingdomSelectionConditionsHold($params)"
}
$m2 = $vmo.GetMethod('MercenaryKingdomSelectionConditionsHold', [Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)
if ($m2) {
    $params = ($m2.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
    Write-Host "  $($m2.ReturnType.Name) MercenaryKingdomSelectionConditionsHold($params)"
}

# Check CanPlayerClanReceiveVassalOffer / CanPlayerClanReceiveMercenaryOffer
Write-Host ""
Write-Host "=== CanPlayerClan methods ==="
foreach ($m in $vmo.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)) {
    if ($m.DeclaringType -eq $vmo -and $m.Name -like 'Can*') {
