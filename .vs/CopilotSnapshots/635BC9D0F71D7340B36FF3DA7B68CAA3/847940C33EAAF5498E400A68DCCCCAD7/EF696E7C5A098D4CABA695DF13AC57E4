$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')

# Find HeroCreation / ClanGeneration behaviors
Write-Host "=== Behaviors related to Hero/Clan generation ==="
$types = $a.GetTypes()
foreach ($t in $types) {
    if ($t.Name -match 'HeroCreat|ClanGenerat|FamilyGen|CharacterCreat|InitialChildGen') {
        Write-Host "  $($t.FullName)"
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)) {
            if ($m.DeclaringType -eq $t) {
                $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                Write-Host "    $($m.Name)($params)"
            }
        }
    }
}

# Hero - remove/disable/kill methods
Write-Host ""
Write-Host "=== Hero removal/disable methods ==="
$heroType = $a.GetType('TaleWorlds.CampaignSystem.Hero')
foreach ($m in $heroType.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Instance -bor [Reflection.BindingFlags]::Static)) {
    if ($m.DeclaringType -eq $heroType -and ($m.Name -match 'Kill|Die|Remove|Disable|SetInactive|ChangeState')) {
        $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  $($m.Name)($params)"
    }
}

# Hero state properties
Write-Host ""
Write-Host "=== Hero state properties ==="
foreach ($p in $heroType.GetProperties([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Instance)) {
    if ($p.Name -match 'State|Alive|Dead|Active|IsChild|Spouse|Father|Mother|Sibling|Children|Clan') {
        $w = if ($p.CanWrite) { 'set' } else { 'readonly' }
        Write-Host "  $($p.PropertyType.Name) $($p.Name) { $w }"
    }
}

# HeroState enum
Write-Host ""
Write-Host "=== Hero.CharacterStates enum ==="
$csType = $a.GetType('TaleWorlds.CampaignSystem.Hero+CharacterStates')
if ($csType) {
    foreach ($v in [Enum]::GetNames($csType)) {
        Write-Host "  $v"
    }
}

# KillCharacterAction
Write-Host ""
Write-Host "=== KillCharacterAction ==="
$kca = $a.GetType('TaleWorlds.CampaignSystem.Actions.KillCharacterAction')
if ($kca) {
    foreach ($m in $kca.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
        if ($m.DeclaringType -eq $kca) {
            $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
            Write-Host "  $($m.Name)($params)"
        }
    }
}

# DisableHeroAction
Write-Host ""
Write-Host "=== DisableHeroAction ==="
foreach ($t in $types) {
    if ($t.Name -like '*DisableHero*') {
        Write-Host "  $($t.FullName)"
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
            if ($m.DeclaringType -eq $t) {
                $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                Write-Host "    $($m.Name)($params)"
            }
        }
    }
}
