$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')

# Clan.Heroes vs Clan.Lords vs Clan.Companions
Write-Host "=== Clan hero collections ==="
$ct = $a.GetType('TaleWorlds.CampaignSystem.Clan')
foreach ($p in $ct.GetProperties()) {
    if ($p.Name -match 'Heroes|Lords|Companions|AliveLords|DeadLords') {
        Write-Host "  $($p.PropertyType.Name) $($p.Name)"
    }
}

# Hero.Clan setter
Write-Host ""
Write-Host "=== Hero.Clan ==="
$ht = $a.GetType('TaleWorlds.CampaignSystem.Hero')
$cp = $ht.GetProperty('Clan')
Write-Host "  CanWrite: $($cp.CanWrite)"

# Hero.HeroState setter
Write-Host ""
Write-Host "=== Hero.HeroState ==="
$hp = $ht.GetProperty('HeroState')
Write-Host "  CanWrite: $($hp.CanWrite)"

# Hero.ChangeState
$cs = $ht.GetMethod('ChangeState')
if ($cs) {
    $params = ($cs.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
    Write-Host "  ChangeState($params)"
}

# InitialChildGenerationCampaignBehavior details
Write-Host ""
Write-Host "=== InitialChildGenerationCampaignBehavior ==="
$icg = $a.GetType('TaleWorlds.CampaignSystem.CampaignBehaviors.InitialChildGenerationCampaignBehavior')
foreach ($m in $icg.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)) {
    if ($m.DeclaringType -eq $icg) {
        $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  $($m.Name)($params)"
    }
}

# Check if there's a way to find heroes by clan
Write-Host ""
Write-Host "=== Hero.FindAll / Hero.AllAliveHeroes ==="
foreach ($p in $ht.GetProperties([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
    if ($p.Name -match 'All|Dead|Alive') {
        Write-Host "  static $($p.PropertyType.Name) $($p.Name)"
    }
}
foreach ($m in $ht.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
    if ($m.DeclaringType -eq $ht -and ($m.Name -match 'FindAll|FindFirst|Find')) {
        $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  static $($m.Name)($params)"
    }
}

# Hero.StringId
Write-Host ""
Write-Host "=== Hero identification ==="
foreach ($p in $ht.GetProperties()) {
    if ($p.Name -match 'StringId|Name|FirstName|CharacterObject') {
        $w = if ($p.CanWrite) { 'set' } else { 'ro' }
        Write-Host "  $($p.PropertyType.Name) $($p.Name) { $w }"
    }
}
