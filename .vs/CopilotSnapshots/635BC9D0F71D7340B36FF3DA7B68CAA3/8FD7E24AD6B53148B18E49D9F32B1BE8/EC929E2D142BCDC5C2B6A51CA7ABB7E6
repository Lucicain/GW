using System;
using System.Linq;
using TaleWorlds.CampaignSystem;
using TaleWorlds.CampaignSystem.MapEvents;
using TaleWorlds.CampaignSystem.Party;
using TaleWorlds.Core;
using TaleWorlds.Library;

namespace GreyWardenPolicePurity
{
    /// <summary>
    /// 警察防宣战系统 - 终极方案：直接对Clan宣战
    /// 
    /// 策略：
    /// 1. 警察接案时：直接对罪犯家族宣战（不影响Kingdom）
    /// 2. 战斗结束后：与罪犯家族和平
    /// 3. 劫匪不需要处理（本来就敌对）
    /// </summary>
    public class PoliceAntiWarDeclaration : CampaignBehaviorBase
    {
        private const string PoliceClanId = "gw";

        public override void RegisterEvents()
        {
            // 战斗结束后：与罪犯家族和平
            CampaignEvents.MapEventEnded.AddNonSerializedListener(this, OnBattleEnded);
        }

        public override void SyncData(IDataStore dataStore) { }

        /// <summary>
        /// 战斗结束：如果警察参与，立即与对方和平
        /// </summary>
        private void OnBattleEnded(MapEvent mapEvent)
        {
            if (mapEvent == null) return;

            Clan policeClan = GetPoliceClan();
            if (policeClan == null) return;

            // 检查警察是否参与 + 找到对手
            bool policeInvolved = false;
            Clan enemyClan = null;

            foreach (var party in mapEvent.InvolvedParties)
            {
                if (party?.MobileParty == null) continue;

                if (IsPoliceParty(party.MobileParty))
                {
                    policeInvolved = true;
                }
                else if (party.MobileParty.ActualClan != null)
                {
                    enemyClan = party.MobileParty.ActualClan;
                }
            }

            // 警察参与了战斗
            if (policeInvolved && enemyClan != null)
            {
                // 野怪不需要和平
                if (IsWildFaction(enemyClan))
                    return;

                // 与贵族家族和平
                MakePeaceWithClan(policeClan, enemyClan);
            }
        }

        /// <summary>
        /// 判断是否是野怪势力（劫匪、山贼）
        /// 雇佣兵不是野怪！即使 IsOutlaw=True
        /// </summary>
        private bool IsWildFaction(IFaction faction)
        {
            if (faction == null) return false;

            if (faction is Clan clan)
            {
                // 优先判断雇佣兵
                if (clan.IsClanTypeMercenary)
                    return false; // 雇佣兵不是野怪

                // 纯野怪：IsOutlaw && IsBanditFaction
                return clan.IsOutlaw && clan.IsBanditFaction;
            }

            return false;
        }

        /// <summary>
        /// 与指定家族和平（使用FactionManager）
        /// </summary>
        private void MakePeaceWithClan(Clan policeClan, Clan enemyClan)
        {
            try
            {
                // 检查是否处于战争
                if (!FactionManager.IsAtWarAgainstFaction(policeClan, enemyClan))
                    return;

                // 使用FactionManager和平（只与家族，不影响Kingdom）
                FactionManager.SetNeutral(policeClan, enemyClan);

                // 显示消息
                string enemyName = enemyClan?.Name?.ToString() ?? "未知";
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP Police] 战后和平：灰袍守卫 与 {enemyName} 家族 恢复和平",
                    Colors.Cyan
                ));
            }
            catch (Exception ex)
            {
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP Error] 和平失败：{ex.Message}",
                    Colors.Red
                ));
            }
        }

        /// <summary>
        /// 判断是否是警察队伍
        /// </summary>
        private bool IsPoliceParty(MobileParty party)
        {
            if (party == null) return false;
            return party.ActualClan != null &&
                   string.Equals(party.ActualClan.StringId, PoliceClanId, StringComparison.OrdinalIgnoreCase);
        }

        /// <summary>
        /// 获取警察家族
        /// </summary>
        private Clan GetPoliceClan()
        {
            return Clan.FindFirst(c =>
                string.Equals(c.StringId, PoliceClanId, StringComparison.OrdinalIgnoreCase));
        }
    }
}