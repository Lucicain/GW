$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')

# InitialChildGenerationCampaignBehavior - the family generator
Write-Host "=== InitialChildGenerationCampaignBehavior - ALL ==="
$icg = $a.GetType('TaleWorlds.CampaignSystem.CampaignBehaviors.InitialChildGenerationCampaignBehavior')
foreach ($m in $icg.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance -bor [Reflection.BindingFlags]::Static)) {
    if ($m.DeclaringType -eq $icg) {
        $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  $($m.Name)($params)"
    }
}

# Also check fields - might have a list of clans to skip
Write-Host ""
Write-Host "=== InitialChildGenerationCampaignBehavior - Fields ==="
foreach ($f in $icg.GetFields([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance -bor [Reflection.BindingFlags]::Static)) {
    Write-Host "  $($f.FieldType.Name) $($f.Name)"
}

# Check ALL behaviors that run on OnNewGameCreatedPartialFollowUp
Write-Host ""
Write-Host "=== ALL behaviors with OnNewGameCreatedPartialFollowUp ==="
$types = $a.GetTypes()
foreach ($t in $types) {
    $m = $t.GetMethod('OnNewGameCreatedPartialFollowUp', [Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)
    if ($m -and $m.DeclaringType -eq $t) {
        Write-Host "  $($t.Name)"
    }
}

# Check HeroCreator - how heroes/spouses are created
Write-Host ""
Write-Host "=== HeroCreator ==="
foreach ($t in $types) {
    if ($t.Name -eq 'HeroCreator') {
        Write-Host "  $($t.FullName)"
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Static -bor [Reflection.BindingFlags]::Instance)) {
            if ($m.DeclaringType -eq $t) {
                $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                Write-Host "    $($m.Name)($params)"
            }
        }
    }
}

# Check FamilyHelper or similar
Write-Host ""
Write-Host "=== FamilyHelper / MarriageHelper ==="
foreach ($t in $types) {
    if ($t.Name -match 'FamilyHelper|MarriageHelper|MarriageAction|SpouseAction') {
        Write-Host "  $($t.FullName)"
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
