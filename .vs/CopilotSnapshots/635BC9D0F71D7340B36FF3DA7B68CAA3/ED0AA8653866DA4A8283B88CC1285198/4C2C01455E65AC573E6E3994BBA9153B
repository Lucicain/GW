$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')

# Check who generates spouses specifically - look for "Spouse" in all method names
Write-Host "=== Methods mentioning Spouse/Marriage/Wife/Husband ==="
$types = $a.GetTypes()
foreach ($t in $types) {
    $methods = $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance -bor [Reflection.BindingFlags]::Static)
    foreach ($m in $methods) {
        if ($m.DeclaringType -eq $t -and ($m.Name -match 'GenerateSpouse|CreateSpouse|AssignSpouse|GenerateFamily|CreateFamily|GenerateChildren|GenerateRelative')) {
            $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
            Write-Host "  $($t.Name).$($m.Name)($params)"
        }
    }
}

