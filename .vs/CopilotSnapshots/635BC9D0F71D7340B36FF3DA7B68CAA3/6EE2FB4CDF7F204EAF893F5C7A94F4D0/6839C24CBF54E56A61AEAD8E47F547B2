# LordPartyComponent.CreateLordParty details
Write-Host "=== LordPartyComponent.CreateLordParty ==="
$lpc = $a.GetType('TaleWorlds.CampaignSystem.Party.PartyComponents.LordPartyComponent')
$m = $lpc.GetMethod('CreateLordParty', [Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)
if ($m) {
    $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.FullName) $($_.Name) default=$($_.HasDefaultValue) $($_.DefaultValue)" }) -join "`n  "
    Write-Host "  $($m.ReturnType.Name) CreateLordParty(`n  $params`n  )"
}

# Who calls CreateLordParty? Search behaviors
Write-Host ""
Write-Host "=== Behaviors with CreateLordParty/SpawnLord ==="
$types = $a.GetTypes()
foreach ($t in $types) {
    $methods = $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance -bor [Reflection.BindingFlags]::Static)
    foreach ($m in $methods) {
        if ($m.DeclaringType -eq $t -and ($m.Name -match 'SpawnLord|CreateLordParty|SpawnWarParty|CreateWarParty|SpawnClanParty')) {
            $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
            Write-Host "  $($t.Name).$($m.Name)($params)"
        }
    }
}

