# How does the game decide to give a lord a party? Check LordPartyComponent
Write-Host ""
Write-Host "=== LordPartyComponent ==="
$lpc = $a.GetType('TaleWorlds.CampaignSystem.Party.PartyComponents.LordPartyComponent')
if ($lpc) {
    foreach ($m in $lpc.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance -bor [Reflection.BindingFlags]::Static)) {
        if ($m.DeclaringType -eq $lpc) {
            $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
            Write-Host "  $($m.Name)($params)"
        }
    }
} else {
    Write-Host "  not found"
}

# Clan.CreateNewMobileParty
Write-Host ""
Write-Host "=== Clan.CreateNewMobileParty ==="
$cnmp = $ct.GetMethod('CreateNewMobileParty', [Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Instance)
if ($cnmp) {
    $params = ($cnmp.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
    Write-Host "  $($cnmp.ReturnType.Name) CreateNewMobileParty($params)"
} else {
    Write-Host "  not found on Clan"
