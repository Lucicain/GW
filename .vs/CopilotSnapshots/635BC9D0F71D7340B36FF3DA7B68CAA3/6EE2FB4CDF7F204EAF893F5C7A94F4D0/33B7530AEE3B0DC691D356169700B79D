$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')
$ht = $a.GetType('TaleWorlds.CampaignSystem.Hero')

# Hero - PartyBelongedTo / CanHaveParty / CanLead
Write-Host "=== Hero - Party/CanLead related ==="
foreach ($p in $ht.GetProperties([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Instance)) {
    if ($p.Name -match 'Party|CanLead|CanHave|GovernorOf|StayingIn|Occupied|IsFaction') {
        $w = if ($p.CanWrite) { 'set' } else { 'ro' }
        Write-Host "  $($p.PropertyType.Name) $($p.Name) { $w }"
    }
}

# Clan - CreateNewMobileParty / how war parties are created
Write-Host ""
Write-Host "=== Clan - party creation methods ==="
$ct = $a.GetType('TaleWorlds.CampaignSystem.Clan')
foreach ($m in $ct.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Instance -bor [Reflection.BindingFlags]::Static)) {
    if ($m.DeclaringType -eq $ct -and ($m.Name -match 'Create|Party|WarParty|Spawn')) {
        $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  $($m.Name)($params)"
    }
}

# MobileParty.CreateParty / CreateNewParty
Write-Host ""
Write-Host "=== MobileParty creation ==="
$mpt = $a.GetType('TaleWorlds.CampaignSystem.Party.MobileParty')
foreach ($m in $mpt.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
    if ($m.DeclaringType -eq $mpt -and $m.Name -match 'Create') {
        $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  $($m.Name)($params)"
    }
}

# WarPartyComponent.MobilePartyCreated / CreateParty
