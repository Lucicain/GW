# Check gw troops
Write-Host ""
Write-Host "=== CharacterObject lookup ==="
$co = $a.GetType('TaleWorlds.CampaignSystem.CharacterObject')
foreach ($m2 in $co.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
    if ($m2.Name -match 'Find|Get') {
        $params = ($m2.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  $($m2.Name)($params) -> $($m2.ReturnType.Name)"
    }
}
