$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')
$module = $a.ManifestModule

# PatrolPartyComponent.CreatePatrolParty - decode IL
Write-Host "=== PatrolPartyComponent.CreatePatrolParty IL ==="
$ppc = $a.GetType('TaleWorlds.CampaignSystem.Party.PartyComponents.PatrolPartyComponent')
$m = $ppc.GetMethod('CreatePatrolParty', [Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)
$body = $m.GetMethodBody()
$il = $body.GetILAsByteArray()
Write-Host "  IL bytes: $($il.Length)"

$i = 0
$callCount = 0
while ($i -lt $il.Length) {
    $op = $il[$i]
    if ($op -eq 0x28 -or $op -eq 0x6F) {
        if ($i + 4 -lt $il.Length) {
            $token = [BitConverter]::ToInt32($il, $i + 1)
            try {
                $method = $module.ResolveMethod($token)
                $callCount++
                Write-Host "  [$callCount] $($method.DeclaringType.Name).$($method.Name)"
            } catch {}
        }
        $i += 5
    } elseif ($op -eq 0x73) {
        if ($i + 4 -lt $il.Length) {
            $token = [BitConverter]::ToInt32($il, $i + 1)
            try {
                $ctor = $module.ResolveMethod($token)
                $callCount++
                Write-Host "  [$callCount] newobj $($ctor.DeclaringType.Name)"
            } catch {}
        }
        $i += 5
    } else { $i++ }
}

# PartyTemplateObject - how to get gw clan's template
