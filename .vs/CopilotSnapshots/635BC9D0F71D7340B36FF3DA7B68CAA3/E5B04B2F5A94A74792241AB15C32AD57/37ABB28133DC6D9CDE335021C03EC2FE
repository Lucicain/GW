$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')
$types = $a.GetTypes()

Write-Host "=== Patrol-related types ==="
foreach ($t in $types) {
    if ($t.Name -match 'Patrol') {
        Write-Host "  $($t.FullName)"
    }
}

Write-Host ""
Write-Host "=== MobileParty.CreateParty ==="
$mp = $a.GetType('TaleWorlds.CampaignSystem.Party.MobileParty')
foreach ($m in $mp.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
    if ($m.Name -match 'Create') {
        $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  $($m.Name)($params)"
    }
}

Write-Host ""
Write-Host "=== PatrolPartyComponent ==="
foreach ($t in $types) {
    if ($t.Name -eq 'PatrolPartyComponent') {
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Static -bor [Reflection.BindingFlags]::Instance)) {
            if ($m.DeclaringType -eq $t -and $m.Name -match 'Create|Spawn|Init') {
                $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                Write-Host "  $($m.Name)($params)"
            }
        }
        Write-Host "  --- Properties ---"
        foreach ($p in $t.GetProperties()) {
            Write-Host "  $($p.PropertyType.Name) $($p.Name)"
        }
    }
}

Write-Host ""
Write-Host "=== EnterSettlementAction ==="
foreach ($t in $types) {
    if ($t.Name -match 'EncounterManager|PlayerEncounter') {
        Write-Host "  $($t.FullName)"
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
            if ($m.DeclaringType -eq $t -and $m.Name -match 'Start|Begin|Init|Encounter') {
                $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                Write-Host "    $($m.Name)($params)"
            }
        }
    }
}
