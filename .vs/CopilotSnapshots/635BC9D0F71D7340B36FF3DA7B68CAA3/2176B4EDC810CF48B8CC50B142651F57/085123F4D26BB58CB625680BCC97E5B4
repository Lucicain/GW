$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')
$c = $a.GetType('TaleWorlds.CampaignSystem.Clan')
$ps = $c.GetProperties()
foreach ($p in $ps) {
    $n = $p.Name
    if ($n -match 'Elim|Minor|Noble|ClanType|Mercenary|Outlaw|Bandit|Rebel|Tier|Fief|Settlement|Destro|Dead|Disband|Kingdom|Clan_type') {
        $w = 'readonly'
        if ($p.CanWrite) { $w = 'set' }
        Write-Host "$($p.PropertyType.Name) $n $w"
    }
}
Write-Host "---"
Write-Host "=== Behaviors that handle clan elimination ==="
$types = $a.GetTypes()
foreach ($t in $types) {
    $methods = $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance -bor [Reflection.BindingFlags]::Static)
    foreach ($m in $methods) {
        if ($m.DeclaringType -eq $t -and ($m.Name -match 'Elim|DestroyC|DisbandC|RemoveC')) {
            Write-Host "$($t.Name).$($m.Name)"
        }
    }
}
