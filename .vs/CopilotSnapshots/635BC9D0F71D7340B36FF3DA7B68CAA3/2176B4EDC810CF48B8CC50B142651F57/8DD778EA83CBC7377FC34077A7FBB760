$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')

# DestroyClanAction.Apply - what are the triggers
Write-Host "=== DestroyClanAction methods ==="
$dca = $a.GetType('TaleWorlds.CampaignSystem.Actions.DestroyClanAction')
foreach ($m in $dca.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
    if ($m.DeclaringType -eq $dca) {
        $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  $($m.Name)($params)"
    }
}

# ClanVariablesCampaignBehavior.DailyTickClan - this is where elimination happens
Write-Host ""
Write-Host "=== ClanVariablesCampaignBehavior - all methods ==="
$cvb = $a.GetType('TaleWorlds.CampaignSystem.CampaignBehaviors.ClanVariablesCampaignBehavior')
foreach ($m in $cvb.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)) {
    if ($m.DeclaringType -eq $cvb) {
        $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
        Write-Host "  $($m.Name)($params)"
    }
}

# Check if there's a Clan.CanBe... method or OnClanDestroyed event
Write-Host ""
Write-Host "=== Events related to clan destroy ==="
$ce = $a.GetType('TaleWorlds.CampaignSystem.CampaignEvents')
foreach ($p in $ce.GetProperties()) {
    if ($p.Name -match 'Destroy|Eliminat|ClanDe') {
        Write-Host "  $($p.Name)"
    }
}

# IsNoble details
Write-Host ""
Write-Host "=== Clan.IsNoble ==="
$ct = $a.GetType('TaleWorlds.CampaignSystem.Clan')
$p = $ct.GetProperty('IsNoble')
Write-Host "  CanRead=$($p.CanRead) CanWrite=$($p.CanWrite)"
$f = $ct.GetFields([Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)
foreach ($fi in $f) {
    if ($fi.Name -match 'noble' -or $fi.Name -match 'Noble') {
        Write-Host "  BackingField: $($fi.Name)"
    }
}

# CommanderLimit - check the model
Write-Host ""
Write-Host "=== DefaultClanTierModel ==="
$types = $a.GetTypes()
foreach ($t in $types) {
    if ($t.Name -like '*ClanTier*') {
        Write-Host "Type: $($t.FullName)"
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Instance)) {
            if ($m.DeclaringType -eq $t) {
                $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                Write-Host "  $($m.Name)($params)"
            }
        }
    }
}
