using System;
using System.Collections.Generic;
using System.Linq;
using TaleWorlds.CampaignSystem;
using TaleWorlds.CampaignSystem.Party;
using TaleWorlds.CampaignSystem.Roster;
using TaleWorlds.CampaignSystem.Settlements;
using TaleWorlds.Core;
using TaleWorlds.Library;
using TaleWorlds.ObjectSystem;
using static TaleWorlds.CampaignSystem.Party.MobileParty;

namespace GreyWardenPolicePurity
{
    /// <summary>
    /// 警察资源管理
    /// 
    /// 1. 每日发薪：每人每天1000金
    /// 2. 任务结束后：前往最近城镇补给
    /// 3. 到达城镇后：补满兵员、释放俘虏、补充粮食
    /// 4. 补给完成后：标记可用，等待接案
    /// </summary>
    public class PoliceResourceManager : CampaignBehaviorBase
    {
        private const int DailyGoldPerMember = 1000;
        private const int FoodDaysTarget = 15;

        // 正在补给中的警察部队ID
        private static readonly HashSet<string> _resupplying = new HashSet<string>();

        /// <summary>
        /// 检查某个警察是否在补给中（供惩戒系统检查）
        /// </summary>
        public static bool IsResupplying(MobileParty party)
        {
            return party != null && _resupplying.Contains(party.StringId);
        }

        /// <summary>
        /// 检查警察是否处于就绪状态（可以接案）
        /// </summary>
        public static bool IsReady(MobileParty party)
        {
            if (party == null || !party.IsActive) return false;
            if (_resupplying.Contains(party.StringId)) return false;
            return true;
        }

        /// <summary>
        /// 触发补给流程（供惩戒系统调用）
        /// </summary>
        public static void StartResupply(MobileParty police)
        {
            if (police == null || !police.IsActive) return;
            if (_resupplying.Contains(police.StringId)) return;

            _resupplying.Add(police.StringId);

            // 找最近的城镇
            Settlement nearestTown = FindNearestTown(police.GetPosition2D);
            if (nearestTown != null)
            {
                police.Ai.SetDoNotMakeNewDecisions(true);
                police.SetMoveGoToSettlement(nearestTown, NavigationType.Default, false);
            }
            else
            {
                // 找不到城镇，直接原地补给
                DoResupply(police);
                FinishResupply(police);
            }
        }

        public override void RegisterEvents()
        {
            CampaignEvents.DailyTickEvent.AddNonSerializedListener(this, OnDailyTick);
            CampaignEvents.HourlyTickEvent.AddNonSerializedListener(this, OnHourlyTick);
        }

        public override void SyncData(IDataStore dataStore) { }

        #region 每日发薪

        private void OnDailyTick()
        {
            PaySalaries();
        }

        private void PaySalaries()
        {
            var parties = PoliceStats.GetAllPoliceParties();

            foreach (var party in parties)
            {
                Hero leader = party.LeaderHero;
                if (leader == null) continue;

                int memberCount = party.Party.NumberOfAllMembers;
                int salary = memberCount * DailyGoldPerMember;

                leader.ChangeHeroGold(salary);
            }
        }

        #endregion

        #region 补给流程

        private void OnHourlyTick()
        {
            CheckResupplyingParties();
        }

        private void CheckResupplyingParties()
        {
            var toFinish = new List<string>();

            foreach (string partyId in _resupplying)
            {
                var party = MobileParty.All.FirstOrDefault(p => p.StringId == partyId);

                // 部队消失
                if (party == null || !party.IsActive)
                {
                    toFinish.Add(partyId);
                    continue;
                }

                // 到达城镇
                if (party.CurrentSettlement != null && party.CurrentSettlement.IsTown)
                {
                    DoResupply(party);
                    toFinish.Add(partyId);
                }
            }

            foreach (string id in toFinish)
            {
                var party = MobileParty.All.FirstOrDefault(p => p.StringId == id);
                if (party != null && party.IsActive)
                {
                    FinishResupply(party);
                }
                _resupplying.Remove(id);
            }
        }

        /// <summary>
        /// 执行补给：补兵 + 释放俘虏 + 补粮
        /// </summary>
        private static void DoResupply(MobileParty police)
        {
            try
            {
                // 1. 释放所有俘虏
                ReleasePrisoners(police);

                // 2. 补充兵员到满
                ReplenishTroops(police);

                // 3. 补充粮食（够15天追捕）
                ReplenishFood(police);
            }
            catch (Exception ex)
            {
                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP Error] 补给失败：{ex.Message}", Colors.Red));
            }
        }

        private static void FinishResupply(MobileParty police)
        {
            // 恢复AI自主
            try
            {
                police.Ai.SetDoNotMakeNewDecisions(false);
                police.Ai.SetInitiative(0f, 0f, 0f);
            }
            catch { }

            InformationManager.DisplayMessage(new InformationMessage(
                $"[GWP 补给] {police.Name} 补给完成（兵员={police.Party.NumberOfAllMembers}/{police.Party.PartySizeLimit} 粮食={police.ItemRoster.TotalFood}）",
                Colors.Green));
        }

        #endregion

        #region 补兵

        private static void ReplenishTroops(MobileParty police)
        {
            int limit = police.Party.PartySizeLimit;
            int current = police.Party.NumberOfAllMembers;
            int needed = limit - current;

            if (needed <= 0) return;

            // 用家族的基础兵种补充
            Clan policeClan = PoliceStats.GetPoliceClan();
            CharacterObject basicTroop = policeClan?.BasicTroop;

            if (basicTroop == null)
            {
                // 找不到基础兵种，尝试用已有兵种
                if (police.MemberRoster.Count > 0)
                {
                    for (int i = 0; i < police.MemberRoster.Count; i++)
                    {
                        CharacterObject troop = police.MemberRoster.GetCharacterAtIndex(i);
                        if (troop != null && !troop.IsHero)
                        {
                            basicTroop = troop;
                            break;
                        }
                    }
                }
            }

            if (basicTroop == null) return;

            police.MemberRoster.AddToCounts(basicTroop, needed);
        }

        #endregion

        #region 释放俘虏

        private static void ReleasePrisoners(MobileParty police)
        {
            if (police.PrisonRoster.TotalManCount > 0)
            {
                police.PrisonRoster.Clear();
            }
        }

        #endregion

        #region 补粮

        private static void ReplenishFood(MobileParty police)
        {
            int currentFood = police.ItemRoster.TotalFood;
            // 目标：每人每天约1份粮食，备15天
            int targetFood = police.Party.NumberOfAllMembers * FoodDaysTarget;
            int needed = targetFood - currentFood;

            if (needed <= 0) return;

            // 找一个食物对象（grain）
            ItemObject foodItem = FindFoodItem();
            if (foodItem == null) return;

            police.ItemRoster.AddToCounts(foodItem, needed);
        }

        private static ItemObject FindFoodItem()
        {
            // 优先找grain
            ItemObject grain = MBObjectManager.Instance.GetObject<ItemObject>("grain");
            if (grain != null) return grain;

            // 找任何食物
            return MBObjectManager.Instance.GetObject<ItemObject>(
                o => o is ItemObject item && item.IsFood) as ItemObject;
        }

        #endregion

        #region 找最近城镇

        private static Settlement FindNearestTown(Vec2 position)
        {
            Settlement nearest = null;
            float minDist = float.MaxValue;

            foreach (Settlement s in Settlement.All)
            {
                if (!s.IsTown) continue;

                float dist = position.Distance(s.GetPosition2D);
                if (dist < minDist)
                {
                    minDist = dist;
                    nearest = s;
                }
            }

            return nearest;
        }

        #endregion
    }
}
