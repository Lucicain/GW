using System;
using System.Collections.Generic;
using System.Linq;
using TaleWorlds.CampaignSystem;
using TaleWorlds.CampaignSystem.Actions;
using TaleWorlds.CampaignSystem.MapEvents;
using TaleWorlds.CampaignSystem.Party;
using TaleWorlds.Core;
using TaleWorlds.Library;
using static TaleWorlds.CampaignSystem.Party.MobileParty;

namespace GreyWardenPolicePurity
{
    /// <summary>
    /// 警察惩戒系统
    /// 
    /// 核心逻辑：
    /// 1. 犯罪入池 → 空闲警察立即接案
    /// 2. 追击阶段：SetMoveEngageParty（不需要宣战）
    /// 3. 接近时：DeclareWar → 游戏自动触发战斗
    /// 4. 战斗结束：SetNeutral + 强制恢复王国成员身份
    /// </summary>
    public class PoliceEnforcementBehavior : CampaignBehaviorBase
    {
        private const string PoliceClanId = "gw";
        private const int MaxActiveTasks = 4;
        private const float WarDeclarationDistance = 8f;

        public static bool IsAcceptingCrimes { get; private set; } = true;

        private List<CrimeRecord> _crimePool = new List<CrimeRecord>();
        private Dictionary<string, PoliceTask> _activeTasks = new Dictionary<string, PoliceTask>();

        public override void RegisterEvents()
        {
            PoliceCrimeMonitorEnhanced.OnCrimeDetected += HandleCrimeDetected;
            CampaignEvents.MapEventEnded.AddNonSerializedListener(this, OnMapEventEnded);
            CampaignEvents.HourlyTickEvent.AddNonSerializedListener(this, OnHourlyTick);
        }

        public override void SyncData(IDataStore dataStore) { }

        #region 犯罪通知

        private void HandleCrimeDetected(string crimeType, MobileParty offender, Vec2 location, string victimName)
        {
            if (offender == null || !offender.IsActive) return;
            if (!IsAcceptingCrimes) return;

            if (_crimePool.Any(c => c.Offender != null && c.Offender.StringId == offender.StringId))
                return;
            if (_activeTasks.Values.Any(t => t.TargetCrime?.Offender?.StringId == offender.StringId))
                return;

            _crimePool.Add(new CrimeRecord
            {
                CrimeId = GenerateUniqueId(),
                CrimeType = crimeType,
                Offender = offender,
                OccurredTime = CampaignTime.Now,
                Location = location,
                VictimName = victimName
            });
            UpdateAcceptingState();
        }

        #endregion

        #region 每小时逻辑

        private void OnHourlyTick()
        {
            AssignTasksToPolice();
            UpdateActiveTasks();
            UpdateAcceptingState();
        }

        private void UpdateAcceptingState()
        {
            int totalTracked = _activeTasks.Count + _crimePool.Count(c => c.IsOffenderValid());
            IsAcceptingCrimes = totalTracked < MaxActiveTasks;
        }

        private void AssignTasksToPolice()
        {
            Clan policeClan = GetPoliceClan();
            if (policeClan == null) return;

            int pendingCrimes = _crimePool.Count(c => c.IsOffenderValid());
            if (pendingCrimes == 0) return;

            foreach (var component in policeClan.WarPartyComponents)
            {
                if (component == null) continue;
                MobileParty policeParty = component.MobileParty;
                if (policeParty == null || !policeParty.IsActive) continue;
                if (_activeTasks.ContainsKey(policeParty.StringId)) continue;

                CrimeRecord nearestCrime = GetNearestCrime(policeParty.GetPosition2D);
                if (nearestCrime == null) continue;

                AssignTask(policeParty, nearestCrime);
            }
        }

        private void AssignTask(MobileParty police, CrimeRecord crime)
        {
            Clan criminalClan = crime.Offender.ActualClan;

            var task = new PoliceTask
            {
                TaskId = GenerateUniqueId(),
                PolicePartyId = police.StringId,
                TargetCrime = crime,
                AssignedTime = CampaignTime.Now,
                Status = TaskStatus.InProgress,
                OriginalClan = criminalClan,
                OriginalKingdom = criminalClan?.Kingdom,
                WarDeclared = false
            };

            _activeTasks[police.StringId] = task;
            _crimePool.Remove(crime);

            // 开始追击（不宣战，先靠近）
            police.SetMoveEngageParty(crime.Offender, NavigationType.Default);
            police.Ai.SetDoNotMakeNewDecisions(true);
            police.Ai.SetInitiative(1f, 0f, 999f);

            UpdateAcceptingState();

            InformationManager.DisplayMessage(new InformationMessage(
                $"[GWP 出警] {police.Name?.ToString()} → {crime.Offender.Name?.ToString()}（{crime.CrimeType}）",
                Colors.Cyan
            ));
        }

        private void UpdateActiveTasks()
        {
            var tasksToRemove = new List<string>();

            foreach (var kvp in _activeTasks)
            {
                var task = kvp.Value;
                var policeParty = MobileParty.All.FirstOrDefault(p => p.StringId == task.PolicePartyId);

                if (policeParty == null || !policeParty.IsActive)
                {
                    tasksToRemove.Add(kvp.Key);
                    continue;
                }

                if (!task.IsTargetValid())
                {
                    EndTask(policeParty, task);
                    tasksToRemove.Add(kvp.Key);
                    continue;
                }

                MobileParty criminal = task.TargetCrime.Offender;

                // 接近时宣战（只宣一次）
                if (!task.WarDeclared)
                {
                    float distance = policeParty.GetPosition2D.Distance(criminal.GetPosition2D);
                    if (distance < WarDeclarationDistance)
                    {
                        DeclareWarOnCriminal(task);
                    }
                    else
                    {
                        // 继续追击
                        policeParty.SetMoveEngageParty(criminal, NavigationType.Default);
                    }
                }
                else
                {
                    // 已宣战，刷新追击
                    policeParty.SetMoveEngageParty(criminal, NavigationType.Default);
                }
            }

            foreach (var key in tasksToRemove)
            {
                _activeTasks.Remove(key);
            }
        }

        /// <summary>
        /// 接近罪犯时宣战
        /// </summary>
        private void DeclareWarOnCriminal(PoliceTask task)
        {
            Clan policeClan = GetPoliceClan();
            Clan criminalClan = task.OriginalClan;
            if (policeClan == null || criminalClan == null) return;

            task.WarDeclared = true;

            // 野怪本来就敌对，不需要宣战
            if (criminalClan.IsOutlaw && criminalClan.IsBanditFaction) return;

            // 关键：用MapFaction作为宣战目标
            // 雇佣兵在王国中时 MapFaction=Kingdom，独立家族时 MapFaction=Clan
            IFaction warTarget = criminalClan.MapFaction;
            task.WarTarget = warTarget;
            task.OriginalKingdom = criminalClan.Kingdom;

            if (!FactionManager.IsAtWarAgainstFaction(policeClan, warTarget))
            {
                try
                {
                    FactionManager.DeclareWar(policeClan, warTarget);
                }
                catch (Exception ex)
                {
                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP Error] 宣战失败：{ex.Message}", Colors.Red));
                }
            }
        }

        #endregion

        #region 战斗结束

        private void OnMapEventEnded(MapEvent mapEvent)
        {
            if (mapEvent == null) return;

            foreach (var kvp in _activeTasks.ToList())
            {
                var task = kvp.Value;
                var policeParty = MobileParty.All.FirstOrDefault(p => p.StringId == task.PolicePartyId);
                if (policeParty == null) continue;

                if (!IsPartyInMapEvent(policeParty, mapEvent)) continue;
                if (!IsPartyInMapEvent(task.TargetCrime.Offender, mapEvent)) continue;

                InformationManager.DisplayMessage(new InformationMessage(
                    $"[GWP 完成] {policeParty.Name?.ToString()} 击败 {task.TargetCrime.Offender.Name?.ToString()}",
                    Colors.Green));

                EndTask(policeParty, task);
                _activeTasks.Remove(kvp.Key);
            }
        }

        private bool IsPartyInMapEvent(MobileParty party, MapEvent mapEvent)
        {
            if (party == null || mapEvent == null) return false;

            foreach (var p in mapEvent.AttackerSide.Parties)
                if (p.Party?.IsMobile == true && p.Party.MobileParty == party) return true;

            foreach (var p in mapEvent.DefenderSide.Parties)
                if (p.Party?.IsMobile == true && p.Party.MobileParty == party) return true;

            return false;
        }

        #endregion

        #region 任务结束（和平 + 恢复王国）

        /// <summary>
        /// 任务结束：恢复AI + 和平 + 强制恢复王国成员
        /// </summary>
        private void EndTask(MobileParty police, PoliceTask task)
        {
            // 恢复警察AI
            try
            {
                police.Ai.SetDoNotMakeNewDecisions(false);
                police.Ai.SetInitiative(0f, 0f, 0f);
            }
            catch { }

            // 恢复外交关系
            if (task.WarDeclared)
            {
                RestoreDiplomacy(task);
            }

            UpdateAcceptingState();
        }

        /// <summary>
        /// 恢复外交：和平 + 强制恢复王国
        /// </summary>
        private void RestoreDiplomacy(PoliceTask task)
        {
            Clan policeClan = GetPoliceClan();
            Clan criminalClan = task.OriginalClan;
            if (policeClan == null || criminalClan == null) return;

            // 野怪不需要处理
            if (criminalClan.IsOutlaw && criminalClan.IsBanditFaction) return;

            // 1. 对宣战目标和平（可能是 Kingdom 或 Clan）
            IFaction warTarget = task.WarTarget ?? criminalClan;
            if (FactionManager.IsAtWarAgainstFaction(policeClan, warTarget))
            {
                try { FactionManager.SetNeutral(policeClan, warTarget); } catch { }
            }

            // 2. 也对家族本身和平（双保险）
            if (warTarget != criminalClan && FactionManager.IsAtWarAgainstFaction(policeClan, criminalClan))
            {
                try { FactionManager.SetNeutral(policeClan, criminalClan); } catch { }
            }

            // 3. 如果家族被踢出王国，强制塞回去
            Kingdom originalKingdom = task.OriginalKingdom;
            if (originalKingdom != null && criminalClan.Kingdom != originalKingdom)
            {
                try
                {
                    if (criminalClan.IsUnderMercenaryService || criminalClan.IsClanTypeMercenary)
                    {
                        ChangeKingdomAction.ApplyByJoinFactionAsMercenary(
                            criminalClan, originalKingdom, CampaignTime.Never, 0, false);
                    }
                    else
                    {
                        ChangeKingdomAction.ApplyByJoinToKingdom(
                            criminalClan, originalKingdom, CampaignTime.Never, false);
                    }
                }
                catch (Exception ex)
                {
                    InformationManager.DisplayMessage(new InformationMessage(
                        $"[GWP Error] 恢复王国失败：{ex.Message}", Colors.Red));
                }
            }
        }

        #endregion

        #region 辅助方法

        private CrimeRecord GetNearestCrime(Vec2 position)
        {
            CrimeRecord nearest = null;
            float minDistance = float.MaxValue;

            foreach (var crime in _crimePool)
            {
                if (!crime.IsOffenderValid()) continue;
                float distance = position.Distance(crime.Offender.GetPosition2D);
                if (distance < minDistance)
                {
                    minDistance = distance;
                    nearest = crime;
                }
            }

            return nearest;
        }

        private string GenerateUniqueId()
        {
            long timestamp = (long)CampaignTime.Now.ToHours;
            int random = MBRandom.RandomInt(1000, 9999);
            return $"CRIME_{timestamp}_{random}";
        }

        private Clan GetPoliceClan()
        {
            return Clan.FindFirst(c =>
                string.Equals(c.StringId, PoliceClanId, StringComparison.OrdinalIgnoreCase));
        }

        #endregion
    }
}