using System.Collections.Generic;
using System.Linq;
using TaleWorlds.CampaignSystem;
using TaleWorlds.CampaignSystem.Party;
using TaleWorlds.Library;

namespace GreyWarden
{
    public class CrimeRecord
    {
        public string CrimeId { get; set; }
        public string CrimeType { get; set; }
        public MobileParty Offender { get; set; }
        public CampaignTime OccurredTime { get; set; }
        public Vec2 Location { get; set; }
        public string VictimName { get; set; }

        public bool IsOffenderValid()
        {
            return Offender != null && Offender.IsActive;
        }
    }

    public class PoliceTask
    {
        public string PolicePartyId { get; set; }
        public CrimeRecord TargetCrime { get; set; }
        public bool WarDeclared { get; set; }
        public IFaction WarTarget { get; set; }

        public bool IsTargetValid()
        {
            return TargetCrime != null && TargetCrime.IsOffenderValid();
        }
    }

    /// <summary>
    /// 警察家族统计工具
    /// </summary>
    public static class PoliceStats
    {
        private const string PoliceClanId = "gw";

        public static Clan GetPoliceClan()
        {
            return Clan.FindFirst(c =>
                string.Equals(c.StringId, PoliceClanId, System.StringComparison.OrdinalIgnoreCase));
        }

        /// <summary>
        /// 获取所有活跃警察部队
        /// </summary>
        public static List<MobileParty> GetAllPoliceParties()
        {
            Clan clan = GetPoliceClan();
            if (clan == null) return new List<MobileParty>();

            return clan.WarPartyComponents
                .Where(w => w?.MobileParty != null && w.MobileParty.IsActive)
                .Select(w => w.MobileParty)
                .ToList();
        }

        /// <summary>
        /// 警察部队总数
        /// </summary>
        public static int PartyCount => GetAllPoliceParties().Count;

        /// <summary>
        /// 案件池上限 = 部队数量
        /// </summary>
        public static int MaxActiveTasks => PartyCount;

        /// <summary>
        /// 家族总人数（所有部队健康成员之和）
        /// </summary>
        public static int TotalHealthyMembers
        {
            get
            {
                return GetAllPoliceParties().Sum(p => p.Party.NumberOfHealthyMembers);
            }
        }

        /// <summary>
        /// 家族总人数（包含伤员）
        /// </summary>
        public static int TotalAllMembers
        {
            get
            {
                return GetAllPoliceParties().Sum(p => p.Party.NumberOfAllMembers);
            }
        }
    }
}
