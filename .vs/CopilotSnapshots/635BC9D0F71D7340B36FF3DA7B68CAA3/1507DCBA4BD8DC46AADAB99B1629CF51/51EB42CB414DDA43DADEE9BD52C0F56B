        $m = $t.GetMethod('CreateChild', [Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)
        if ($m) {
            $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
            Write-Host "  CreateChild($params)"
        }
        $m2 = $t.GetMethod('DeliverOffSpring', [Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)
        if ($m2) {
            $params = ($m2.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
            Write-Host "  DeliverOffSpring($params)"
        }
    }
}

