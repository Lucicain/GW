# InitialChildGenerationCampaignBehavior IL - we already know the flow:
# It iterates Clan.AliveLords, checks IsChild and IsFemale
# Let's trace what it does with "children" and "age"

# Resolve more tokens from the IL
$icg = $a.GetType('TaleWorlds.CampaignSystem.CampaignBehaviors.InitialChildGenerationCampaignBehavior')
$module = $icg.Module

# Key tokens from IL we haven't resolved yet
$tokens = @(
    0x06000D61,  # Hero.Spouse
    0x06000D29,  # Hero.Age
    0x06000D09,  # Hero.IsAlive
    0x06000CFE,  # Hero.Occupation
    0x06000D32,  # Hero.Clan
    0x06001241,  # likely HeroCreator method
    0x06000D53   # Hero.Children?
)

Write-Host "=== Resolving additional tokens ==="
foreach ($token in $tokens) {
    try {
        $method = $module.ResolveMethod($token)
        Write-Host "  0x$($token.ToString('X8')): $($method.DeclaringType.Name).$($method.Name)"
    } catch {
        Write-Host "  0x$($token.ToString('X8')): FAILED"
    }
}

# HeroCreator.CreateChild
