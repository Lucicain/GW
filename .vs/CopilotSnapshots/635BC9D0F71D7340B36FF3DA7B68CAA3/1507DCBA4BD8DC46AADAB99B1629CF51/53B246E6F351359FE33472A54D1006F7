$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')
$icg = $a.GetType('TaleWorlds.CampaignSystem.CampaignBehaviors.InitialChildGenerationCampaignBehavior')
$module = $icg.Module
$m = $icg.GetMethod('OnNewGameCreatedPartialFollowUp', [Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance)
$il = $m.GetMethodBody().GetILAsByteArray()

# Resolve ALL call/callvirt tokens in the IL
Write-Host "=== ALL method calls in InitialChildGeneration ==="
$i = 0
$callCount = 0
while ($i -lt $il.Length) {
    $op = $il[$i]
    # 28 = call, 6F = callvirt (both followed by 4-byte token)
    if ($op -eq 0x28 -or $op -eq 0x6F) {
        if ($i + 4 -lt $il.Length) {
            $token = [BitConverter]::ToInt32($il, $i + 1)
            $callType = if ($op -eq 0x28) { "call" } else { "callvirt" }
            try {
                $method = $module.ResolveMethod($token)
                $callCount++
                Write-Host "  [$callCount] offset=$i $callType $($method.DeclaringType.Name).$($method.Name)"
            } catch {
                $callCount++
                Write-Host "  [$callCount] offset=$i $callType token=0x$($token.ToString('X8')) (unresolved)"
            }
        }
        $i += 5
    }
    # 73 = newobj
    elseif ($op -eq 0x73) {
        if ($i + 4 -lt $il.Length) {
            $token = [BitConverter]::ToInt32($il, $i + 1)
            try {
                $ctor = $module.ResolveMethod($token)
                $callCount++
                Write-Host "  [$callCount] offset=$i newobj $($ctor.DeclaringType.Name)..ctor"
            } catch {}
        }
        $i += 5
    }
    else {
        $i++
    }
}
