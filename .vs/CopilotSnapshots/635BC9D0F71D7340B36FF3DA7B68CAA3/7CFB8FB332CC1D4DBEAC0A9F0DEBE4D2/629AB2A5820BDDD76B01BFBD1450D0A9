$a = [Reflection.Assembly]::LoadFrom('D:\steam\steamapps\common\Mount & Blade II Bannerlord\bin\Win64_Shipping_Client\TaleWorlds.CampaignSystem.dll')
$types = $a.GetTypes()

# How does the game decide to capture a hero after battle?
# Look for TakePrisoner / MakePrisoner / CaptureHero
Write-Host "=== Prisoner-related Actions ==="
foreach ($t in $types) {
    if ($t.Name -match 'Prisoner|Capture') {
        Write-Host "  $($t.FullName)"
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::Static)) {
            if ($m.DeclaringType -eq $t) {
                $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                Write-Host "    $($m.Name)($params)"
            }
        }
    }
}

# LordPartyComponent - what it stores
Write-Host ""
Write-Host "=== LordPartyComponent properties ==="
$lpc = $a.GetType('TaleWorlds.CampaignSystem.Party.PartyComponents.LordPartyComponent')
foreach ($p in $lpc.GetProperties()) {
    $w = if ($p.CanWrite) { 'set' } else { 'ro' }
    Write-Host "  $($p.PropertyType.Name) $($p.Name) { $w }"
}

# Check Hero.CanDie - what determines if hero can die/be captured
Write-Host ""
Write-Host "=== Hero.CanDie ==="
$ht = $a.GetType('TaleWorlds.CampaignSystem.Hero')
$cd = $ht.GetMethod('CanDie')
if ($cd) {
    $params = ($cd.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
    Write-Host "  CanDie($params)"
}

# Hero properties that affect capture
Write-Host ""
Write-Host "=== Hero capture-related properties ==="
foreach ($p in $ht.GetProperties()) {
    if ($p.Name -match 'Prisoner|Captive|CanBe|IsLord|Occupation|Clan|IsClanLeader') {
        $w = if ($p.CanWrite) { 'set' } else { 'ro' }
        Write-Host "  $($p.PropertyType.Name) $($p.Name) { $w }"
    }
}

# MapEventHelper or MapEventProcessor - who handles post-battle capture
Write-Host ""
Write-Host "=== Post-battle processing ==="
foreach ($t in $types) {
    if ($t.Name -match 'MapEventProcessor|BattleEndLogic|AfterBattle') {
        Write-Host "  $($t.FullName)"
        foreach ($m in $t.GetMethods([Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Instance -bor [Reflection.BindingFlags]::Static)) {
            if ($m.DeclaringType -eq $t -and $m.Name -match 'Capture|Prisoner|Process|Aftermath') {
                $params = ($m.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                Write-Host "    $($m.Name)($params)"
            }
        }
    }
}

# Check MobilePartyHelper.SpawnLordParty vs normal party creation
Write-Host ""
Write-Host "=== MobilePartyHelper.SpawnLordPartyAux ==="
$mph = $null
foreach ($t in $types) { if ($t.Name -eq 'MobilePartyHelper') { $mph = $t; break } }
$m2 = $mph.GetMethod('SpawnLordPartyAux', [Reflection.BindingFlags]::Public -bor [Reflection.BindingFlags]::NonPublic -bor [Reflection.BindingFlags]::Static)
if ($m2) {
    $params = ($m2.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
    Write-Host "  SpawnLordPartyAux($params)"
    $body = $m2.GetMethodBody()
    Write-Host "  IL bytes: $($body.GetILAsByteArray().Length)"
}

# Check if Occupation matters for capture
Write-Host ""
Write-Host "=== Occupation values ==="
$occType = $a.GetType('TaleWorlds.CampaignSystem.Occupation')
foreach ($v in [Enum]::GetValues($occType)) {
    Write-Host "  $([int]$v) = $v"
}
